{%- comment -%}
  Usage: {% render 'swatch-color', name: value %} -> outputs a hex color for a colour name.
{%- endcomment -%}
{%- assign c = name | downcase | strip -%}
{%- case c -%}
  {%- when 'beige' -%}#C9B8A8
  {%- when 'black' -%}#1A1A1A
  {%- when 'blue' -%}#2255AA
  {%- when 'brown' -%}#6B4226
  {%- when 'gray', 'grey', 'charcoal grey' -%}#7A7A7A
  {%- when 'green' -%}#2E7D4F
  {%- when 'navy' -%}#1A1A2E
  {%- when 'pink' -%}#E8A0B4
  {%- when 'plum', 'purple' -%}#7F285B
  {%- when 'silver' -%}#C0C0C0
  {%- when 'white' -%}#F5F5F5
  {%- when 'yellow' -%}#F2C12E
  {%- when 'cream' -%}#F2E8E0
  {%- when 'charcoal' -%}#3A3A3A
  {%- when 'oak', 'natural' -%}#C8A878
  {%- else -%}#CCCCCC
{%- endcase -%}
