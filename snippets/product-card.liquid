{%- comment -%}
  Premium product card.
  Usage: {% render 'product-card', product: product, filter_colour: filter_colour %}
{%- endcomment -%}

{%- assign on_sale = false -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign on_sale = true -%}
{%- endif -%}
{%- assign is_new = false -%}
{%- if product.tags contains 'new' -%}{%- assign is_new = true -%}{%- endif -%}
{%- assign has_alt_img = false -%}
{%- if product.images.size > 1 -%}
  {%- assign has_alt_img = true -%}
{%- endif -%}

{%- comment -%} Find colour option if it exists {%- endcomment -%}
{%- assign color_option = nil -%}
{%- for option in product.options_with_values -%}
  {%- assign opt_name_down = option.name | downcase -%}
  {%- if opt_name_down == 'color' or opt_name_down == 'colour' -%}
    {%- assign color_option = option -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} If a colour filter is active, find the colour-matched image {%- endcomment -%}
{%- assign card_primary_img = product.featured_image -%}
{%- assign card_alt_img = product.images[1] -%}
{%- if filter_colour != blank -%}
  {%- assign _colour_img_found = false -%}

  {%- comment -%} Path 1: variant has an image assigned directly {%- endcomment -%}
  {%- for variant in product.variants -%}
    {%- assign v_opt1 = variant.option1 | downcase -%}
    {%- assign v_opt2 = variant.option2 | downcase -%}
    {%- assign v_opt3 = variant.option3 | downcase -%}
    {%- if v_opt1 == filter_colour or v_opt2 == filter_colour or v_opt3 == filter_colour -%}
      {%- if variant.featured_image -%}
        {%- assign card_primary_img    = variant.featured_image -%}
        {%- assign card_alt_img        = nil -%}
        {%- assign _colour_img_found   = true -%}
        {%- for img in product.images -%}
          {%- assign _ialt = img.alt | split: '–' | last | strip | downcase -%}
          {%- if _ialt == filter_colour and img.id != card_primary_img.id -%}
            {%- assign card_alt_img = img -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%}
    Path 2 (fallback): no variant image — scan product images by alt text.
    Matches "Product Name – Colour" pattern OR any alt text containing the colour word.
  {%- endcomment -%}
  {%- unless _colour_img_found -%}
    {%- for img in product.images -%}
      {%- assign _ialt = img.alt | downcase -%}
      {%- assign _ialt_colour = _ialt | split: '–' | last | strip -%}
      {%- if _ialt_colour == filter_colour or _ialt contains filter_colour -%}
        {%- assign card_primary_img  = img -%}
        {%- assign card_alt_img      = nil -%}
        {%- assign _colour_img_found = true -%}
        {%- for img2 in product.images -%}
          {%- if img2.id != card_primary_img.id -%}
            {%- assign _i2alt = img2.alt | downcase -%}
            {%- assign _i2alt_colour = _i2alt | split: '–' | last | strip -%}
            {%- if _i2alt_colour == filter_colour or _i2alt contains filter_colour -%}
              {%- assign card_alt_img = img2 -%}
              {%- break -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endunless -%}
{%- endif -%}

<article class="product-card" itemscope itemtype="https://schema.org/Product">

  {%- comment -%} ---- IMAGE + OVERLAY AREA ---------------------------------- {%- endcomment -%}
  <div class="product-card__img-wrap">

    {%- comment -%} Badges {%- endcomment -%}
    {%- if on_sale or is_new -%}
      <div class="product-card__badges">
        {%- if on_sale -%}
          {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="product-card__badge product-card__badge--sale">-{{ save_pct }}%</span>
        {%- elsif is_new -%}
          <span class="product-card__badge product-card__badge--new">New</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Wishlist {%- endcomment -%}
    <button
      class="product-card__wishlist"
      aria-label="Save {{ product.title | escape }} to wishlist"
      type="button">
      <svg width="17" height="16" viewBox="0 0 18 17" fill="none" aria-hidden="true">
        <path d="M9 15.5s-7-3.8-7-9.25a4.25 4.25 0 0 1 7-3.22A4.25 4.25 0 0 1 16 6.25C16 11.7 9 15.5 9 15.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      </svg>
    </button>

    {%- comment -%} Images {%- endcomment -%}
    <a href="{{ product.url }}"
       class="product-card__img{% if has_alt_img %} has-alt-img{% endif %}"
       tabindex="-1"
       aria-label="{{ product.title | escape }}"
       aria-hidden="true">
      {%- if card_primary_img -%}
        <img
          class="product-card__img--primary"
          src="{{ card_primary_img | image_url: width: 600 }}"
          srcset="{{ card_primary_img | image_url: width: 300 }} 300w,
                  {{ card_primary_img | image_url: width: 600 }} 600w,
                  {{ card_primary_img | image_url: width: 900 }} 900w"
          sizes="(max-width: 480px) 50vw, (max-width: 768px) 50vw, (max-width: 1100px) 33vw, 22vw"
          alt="{{ card_primary_img.alt | escape | default: product.title }}"
          loading="lazy"
          width="600"
          height="450"
          itemprop="image">
        {%- if card_alt_img -%}
          <img
            class="product-card__img--alt"
            src="{{ card_alt_img | image_url: width: 600 }}"
            alt="{{ card_alt_img.alt | escape | default: product.title }}"
            loading="lazy"
            width="600"
            height="450">
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </a>

    {%- comment -%} Hover action overlay {%- endcomment -%}
    <div class="product-card__actions" aria-hidden="true">
      {%- if product.variants.size == 1 and product.available -%}
        <button
          class="product-card__action-btn product-card__action-btn--atc"
          type="button"
          data-add-to-cart
          data-variant-id="{{ product.variants[0].id }}"
          data-original-text="Add to Basket">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 1h2l1.4 7h6.1l1-5H3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="5.5" cy="12" r="1" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="10" cy="12" r="1" stroke="currentColor" stroke-width="1.3"/>
          </svg>
          Add to Basket
        </button>
      {%- endif -%}
      <a href="{{ product.url }}" class="product-card__action-btn product-card__action-btn--view">
        View Details
      </a>
    </div>
  </div>

  {%- comment -%} ---- INFO AREA --------------------------------------------- {%- endcomment -%}
  <div class="product-card__info">

    {%- comment -%} Product type badge (e.g. "Divan Bed", "Ottoman Bed") {%- endcomment -%}
    {%- if product.type != blank -%}
      <span class="product-card__type">{{ product.type }}</span>
    {%- endif -%}

    <a href="{{ product.url }}" class="product-card__title" itemprop="name">{{ product.title }}</a>

    {%- comment -%} Colour swatches (only if colour option exists) {%- endcomment -%}
    {%- if color_option -%}
      <div class="product-card__swatches" aria-label="Colours available">
        {%- for value in color_option.values limit: 5 -%}
          <span class="product-card__swatch" style="background:{% render 'swatch-color', name: value %};" title="{{ value }}"></span>
        {%- endfor -%}
        {%- if color_option.values.size > 5 -%}
          <span class="product-card__swatch-more">+{{ color_option.values.size | minus: 5 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Pricing — show "From" for multi-variant products {%- endcomment -%}
    <div class="product-card__pricing" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      {%- if on_sale -%}
        {%- if product.variants.size > 1 -%}
          <span class="product-card__from">From</span>
        {%- endif -%}
        <span class="product-card__price product-card__price--sale" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">{{ product.price | money }}</span>
        <span class="product-card__compare">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        {%- if product.variants.size > 1 -%}
          <span class="product-card__from">From</span>
        {%- endif -%}
        <span class="product-card__price" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">{{ product.price | money }}</span>
      {%- endif -%}
    </div>
    {%- if on_sale -%}
      {%- assign save_amount = product.compare_at_price | minus: product.price -%}
      <span class="product-card__save">Save {{ save_amount | money }}</span>
    {%- endif -%}
  </div>

  {%- comment -%} Image data for JS colour swap — s=src, a=alt {%- endcomment -%}
  <script type="application/json" class="kl-card-imgs">[{%- for img in product.images -%}{"s":{{ img | image_url: width: 600 | json }},"a":{{ img.alt | default: '' | json }}}{% unless forloop.last %},{%- endunless -%}{%- endfor -%}]</script>

</article>
