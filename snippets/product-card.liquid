{%- comment -%}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- assign on_sale = false -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign on_sale = true -%}
{%- endif -%}

<div class="product-card">

  {%- if on_sale -%}
    <span class="product-card__badge" aria-label="Sale">Sale</span>
  {%- elsif product.tags contains 'new' -%}
    <span class="product-card__badge product-card__badge--new" aria-label="New">New</span>
  {%- endif -%}

  <div class="product-card__img-wrap">
    <a href="{{ product.url }}" class="product-card__img" aria-label="{{ product.title | escape }}">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 500 }}"
          srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                  {{ product.featured_image | image_url: width: 500 }} 500w,
                  {{ product.featured_image | image_url: width: 700 }} 700w"
          sizes="(max-width: 480px) 50vw, (max-width: 768px) 50vw, (max-width: 992px) 33vw, 25vw"
          alt="{{ product.featured_image.alt | escape | default: product.title }}"
          loading="lazy"
          width="500"
          height="375">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </a>

    <button class="product-card__wishlist" aria-label="Add {{ product.title | escape }} to wishlist">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M9 15.5s-7-3.8-7-9.25a4.25 4.25 0 0 1 7-3.22A4.25 4.25 0 0 1 16 6.25C16 11.7 9 15.5 9 15.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="product-card__info">
    <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>
    <div class="product-card__pricing">
      <span class="product-card__price">{{ product.price | money }}</span>
      {%- if on_sale -%}
        <span class="product-card__compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
    {%- if on_sale -%}
      {%- assign save_amount = product.compare_at_price | minus: product.price -%}
      <span class="product-card__save">Save {{ save_amount | money }}</span>
    {%- endif -%}

    {%- assign color_values = blank -%}
    {%- for option in product.options_with_values -%}
      {%- if option.name == 'Color' or option.name == 'Colour' -%}
        {%- assign color_values = option.values -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if color_values != blank -%}
      <div class="product-card__swatches">
        {%- for value in color_values limit: 6 -%}
          <span class="product-card__swatch" style="background:{% render 'swatch-color', name: value %};" title="{{ value }}"></span>
        {%- endfor -%}
        {%- if color_values.size > 6 -%}
          <span class="product-card__swatch-more">+{{ color_values.size | minus: 6 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

</div>
