<script>
(function () {

  /* ---- Mobile filter drawer --------------------------------- */
  function klOpenFilters() {
    document.getElementById('kl-drawer').classList.add('is-open');
    document.getElementById('kl-overlay').classList.add('is-visible');
    document.body.style.overflow = 'hidden';
  }
  function klCloseFilters() {
    document.getElementById('kl-drawer').classList.remove('is-open');
    document.getElementById('kl-overlay').classList.remove('is-visible');
    document.body.style.overflow = '';
  }
  window.klOpenFilters  = klOpenFilters;
  window.klCloseFilters = klCloseFilters;
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') klCloseFilters();
  });

  /* ---- Price range dual slider ------------------------------ */
  var wrap = document.querySelector('.kl-slider-wrap');
  if (wrap) {
    var rangeMax  = parseInt(wrap.dataset.range, 10);
    var thumbMin  = document.getElementById('kl-slider-min');
    var thumbMax  = document.getElementById('kl-slider-max');
    var fill      = document.getElementById('kl-slider-fill');
    var labelMin  = document.getElementById('kl-price-min-label');
    var labelMax  = document.getElementById('kl-price-max-label');
    var valMin    = document.getElementById('kl-price-min-val');
    var valMax    = document.getElementById('kl-price-max-val');

    function fmt(cents) {
      return '£' + (cents / 100).toFixed(2);
    }

    function render() {
      var lo = parseInt(thumbMin.value, 10);
      var hi = parseInt(thumbMax.value, 10);
      var loP = (lo / rangeMax) * 100;
      var hiP = (hi / rangeMax) * 100;
      fill.style.left  = loP + '%';
      fill.style.width = (hiP - loP) + '%';
      labelMin.textContent = fmt(lo);
      labelMax.textContent = fmt(hi);
      valMin.value = lo;
      valMax.value = hi;
    }

    thumbMin.addEventListener('input', function () {
      if (parseInt(thumbMin.value, 10) > parseInt(thumbMax.value, 10) - 50) {
        thumbMin.value = parseInt(thumbMax.value, 10) - 50;
      }
      render();
    });
    thumbMax.addEventListener('input', function () {
      if (parseInt(thumbMax.value, 10) < parseInt(thumbMin.value, 10) + 50) {
        thumbMax.value = parseInt(thumbMin.value, 10) + 50;
      }
      render();
    });
    thumbMin.addEventListener('change', function () {
      document.getElementById('kl-price-form').submit();
    });
    thumbMax.addEventListener('change', function () {
      document.getElementById('kl-price-form').submit();
    });

    render();
  }

  /* ---- Reviews carousel ------------------------------------ */
  (function () {
    var track = document.getElementById('kl-rev-track');
    var prev  = document.getElementById('kl-rev-prev');
    var next  = document.getElementById('kl-rev-next');
    if (!track || !prev || !next) return;
    var pos = 0;
    function cardW() {
      var c = track.querySelector('.kl-review-card');
      return c ? c.offsetWidth + 16 : 220;
    }
    function maxPos() {
      return Math.max(0, track.scrollWidth - track.parentElement.offsetWidth);
    }
    function go(dir) {
      pos = Math.min(Math.max(0, pos + dir * cardW()), maxPos());
      track.style.transform = 'translateX(-' + pos + 'px)';
      prev.disabled = pos <= 0;
      next.disabled = pos >= maxPos();
    }
    prev.addEventListener('click', function () { go(-1); });
    next.addEventListener('click', function () { go(1); });
    prev.disabled = true;
  })();

})();
</script>

