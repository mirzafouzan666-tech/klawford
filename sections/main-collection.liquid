{%- paginate collection.products by section.settings.products_per_page -%}

{%- assign active_filter_count = 0 -%}
{%- for filter in collection.active_filters -%}
  {%- assign active_filter_count = active_filter_count | plus: 1 -%}
{%- endfor -%}

{%- comment -%} ================================================================
    MOBILE FILTER DRAWER
    ================================================================ {%- endcomment -%}
<div class="kl-overlay" id="kl-overlay" onclick="klCloseFilters()"></div>

<aside class="kl-drawer" id="kl-drawer" role="dialog" aria-modal="true" aria-label="Product filters">
  <div class="kl-drawer__head">
    <span class="kl-drawer__title">
      <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true">
        <path d="M1 2h14M4 7h8M7 12h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Filters
    </span>
    <button class="kl-drawer__close" onclick="klCloseFilters()" aria-label="Close filters" type="button">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="kl-drawer__body">
    {%- comment -%} Static Size filter for drawer {%- endcomment -%}
    <div class="kl-fg is-open" data-fg>
      <button class="kl-fg__head" type="button" onclick="this.closest('[data-fg]').classList.toggle('is-open')">
        <svg class="kl-fg__chevron" width="10" height="7" viewBox="0 0 12 8" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Size</span>
      </button>
      <div class="kl-fg__body">
        <div class="kl-swatch-list">
          {%- assign bed_sizes_d = 'Small Single 2FT6,Single 3FT,Small Double 4FT,Double 4FT6,King 5FT,Super King 6FT' | split: ',' -%}
          {%- for size in bed_sizes_d -%}
            <label class="kl-swatch-item">
              <input type="checkbox"
                name="filter.p.v.option.size"
                value="{{ size }}"
                form="kl-form-drawer"
                onchange="document.getElementById('kl-form-drawer').submit()">
              <span class="kl-swatch-name">{{ size }}</span>
            </label>
          {%- endfor -%}
        </div>
      </div>
    </div>

    {%- for filter in collection.filters -%}
      {%- if filter.label == 'Availability' -%}{%- continue -%}{%- endif -%}
      {%- if filter.label == 'Bedding size' -%}{%- continue -%}{%- endif -%}
      <div class="kl-fg is-open" data-fg>
        <button class="kl-fg__head" type="button" onclick="this.closest('[data-fg]').classList.toggle('is-open')">
          <svg class="kl-fg__chevron" width="10" height="7" viewBox="0 0 12 8" fill="none" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{% if filter.label == 'Bedding size' %}Size{% else %}{{ filter.label }}{% endif %}</span>
          {%- if filter.active_values.size > 0 -%}
            <span class="kl-fg__badge">{{ filter.active_values.size }}</span>
          {%- endif -%}
        </button>
        <div class="kl-fg__body">
          {%- if filter.type == 'price_range' -%}
            <div class="kl-price-inputs">
              <label class="kl-price-field">
                <span>£</span>
                <input type="number" min="0" name="{{ filter.min_value.param_name }}"
                  value="{{ filter.min_value.value }}" placeholder="0"
                  form="kl-form-drawer"
                  onchange="document.getElementById('kl-form-drawer').submit()">
              </label>
              <span class="kl-price-sep">–</span>
              <label class="kl-price-field">
                <span>£</span>
                <input type="number" min="0" name="{{ filter.max_value.param_name }}"
                  value="{{ filter.max_value.value }}"
                  placeholder="{{ filter.range_max | money_without_currency }}"
                  form="kl-form-drawer"
                  onchange="document.getElementById('kl-form-drawer').submit()">
              </label>
            </div>
          {%- elsif filter.type == 'list' -%}
            {%- assign fl_lower_d = filter.label | downcase -%}
            {%- assign is_colour_d = false -%}
            {%- if fl_lower_d == 'color' or fl_lower_d == 'colour' -%}{%- assign is_colour_d = true -%}{%- endif -%}
            <div class="kl-swatch-list">
              {%- for value in filter.values -%}
                <label class="kl-swatch-item{% if value.count == 0 %} is-disabled{% endif %}">
                  <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                    {% if value.active %}checked{% endif %}
                    {% if value.count == 0 %}disabled{% endif %}
                    form="kl-form-drawer"
                    onchange="document.getElementById('kl-form-drawer').submit()">
                  {%- if filter.presentation == 'swatch' -%}
                    <span class="kl-swatch-dot{% if value.active %} is-checked{% endif %}" style="background:{{ value.swatch.color }};"></span>
                  {%- elsif is_colour_d -%}
                    <span class="kl-swatch-dot{% if value.active %} is-checked{% endif %}" style="background:{%- render 'swatch-color', name: value.label -%};"></span>
                  {%- endif -%}
                  <span class="kl-swatch-name">{{ value.label }}</span>
                </label>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="kl-drawer__foot">
    {%- if active_filter_count > 0 -%}
      <a href="{{ collection.url }}" class="kl-drawer__clear">Clear all</a>
    {%- endif -%}
    <button class="btn btn--primary kl-drawer__apply" onclick="klCloseFilters()" type="button">
      View {{ collection.products_count }} Products
    </button>
  </div>
</aside>

<form id="kl-form-drawer" method="get" action="{{ collection.url }}">
  <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
</form>

{%- comment -%} ================================================================
    COLLECTION PAGE
    ================================================================ {%- endcomment -%}
<div class="kl-col-page">
  <div class="container">

    {%- comment -%} Mobile bar {%- endcomment -%}
    <div class="kl-mobile-bar">
      <button class="kl-mobile-filter-btn" onclick="klOpenFilters()" type="button">
        <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true">
          <path d="M1 2h14M4 7h8M7 12h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Filters
        {%- if active_filter_count > 0 -%}
          <span class="kl-mobile-filter-btn__count">{{ active_filter_count }}</span>
        {%- endif -%}
      </button>
      <select class="kl-mobile-sort" aria-label="Sort products"
        onchange="window.location.href='{{ collection.url }}?sort_by=' + this.value">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        {%- for option in collection.sort_options -%}
          <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
        {%- endfor -%}
      </select>
    </div>

    <div class="kl-col-layout">

      {%- comment -%} ---- LEFT SIDEBAR ----------------------------------------- {%- endcomment -%}
      <aside class="kl-sidebar" aria-label="Filter products">

        {%- if active_filter_count > 0 -%}
          <a href="{{ collection.url }}" class="kl-sidebar-clear">Clear all filters</a>
        {%- endif -%}

        {%- comment -%} 1. PRICE filter (from API) {%- endcomment -%}
        {%- for filter in collection.filters -%}
          {%- unless filter.type == 'price_range' -%}{%- continue -%}{%- endunless -%}
          {%- assign pr_min = filter.min_value.value | default: 0 -%}
          {%- assign pr_max = filter.max_value.value | default: filter.range_max -%}
          <div class="kl-fg is-open" data-fg>
            <button class="kl-fg__head" type="button" onclick="this.closest('[data-fg]').classList.toggle('is-open')">
              <svg class="kl-fg__chevron" width="10" height="7" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Price</span>
            </button>
            <div class="kl-fg__body">
              <div class="kl-slider-wrap"
                   data-range="{{ filter.range_max }}"
                   data-cur-min="{{ pr_min }}"
                   data-cur-max="{{ pr_max }}">
                <div class="kl-slider-track">
                  <div class="kl-slider-fill" id="kl-slider-fill"></div>
                </div>
                <input class="kl-slider-thumb kl-slider-thumb--min" type="range"
                  id="kl-slider-min"
                  min="0" max="{{ filter.range_max }}" value="{{ pr_min }}" step="1"
                  aria-label="Minimum price">
                <input class="kl-slider-thumb kl-slider-thumb--max" type="range"
                  id="kl-slider-max"
                  min="0" max="{{ filter.range_max }}" value="{{ pr_max }}" step="1"
                  aria-label="Maximum price">
              </div>
              <div class="kl-slider-labels">
                <span id="kl-price-min-label">{{ pr_min | money }}</span>
                <span id="kl-price-max-label">{{ pr_max | money }}</span>
              </div>
              <form id="kl-price-form" method="get" action="{{ collection.url }}">
                <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
                <input type="hidden" id="kl-price-min-val" name="{{ filter.min_value.param_name }}" value="{{ pr_min }}">
                <input type="hidden" id="kl-price-max-val" name="{{ filter.max_value.param_name }}" value="{{ pr_max }}">
                {%- for af in collection.active_filters -%}
                  {%- unless af.param_name == filter.min_value.param_name or af.param_name == filter.max_value.param_name -%}
                    <input type="hidden" name="{{ af.param_name }}" value="{{ af.value }}">
                  {%- endunless -%}
                {%- endfor -%}
              </form>
            </div>
          </div>
        {%- endfor -%}

        {%- comment -%} 2. SIZE filter (static — edit product options to make functional) {%- endcomment -%}
        <div class="kl-fg is-open" data-fg>
          <button class="kl-fg__head" type="button" onclick="this.closest('[data-fg]').classList.toggle('is-open')">
            <svg class="kl-fg__chevron" width="10" height="7" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Size</span>
          </button>
          <div class="kl-fg__body">
            <div class="kl-swatch-list">
              {%- assign bed_sizes = 'Small Single 2FT6,Single 3FT,Small Double 4FT,Double 4FT6,King 5FT,Super King 6FT' | split: ',' -%}
              {%- for size in bed_sizes -%}
                {%- assign size_param = size | url_encode -%}
                {%- assign size_active = false -%}
                {%- if request.query_string contains size_param -%}{%- assign size_active = true -%}{%- endif -%}
                <label class="kl-swatch-item">
                  <input type="checkbox"
                    name="filter.p.v.option.size"
                    value="{{ size }}"
                    {% if size_active %}checked{% endif %}
                    form="kl-form-sidebar"
                    onchange="document.getElementById('kl-form-sidebar').submit()">
                  <span class="kl-swatch-name">{{ size }}</span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        </div>

        {%- comment -%} 3. COLOUR filter (static — always shows all 5 colours) {%- endcomment -%}
        {%- assign colour_param = 'filter.p.v.option.colour' -%}
        {%- for filter in collection.filters -%}
          {%- assign fl_lower = filter.label | downcase -%}
          {%- if fl_lower == 'color' or fl_lower == 'colour' -%}
            {%- if filter.values.size > 0 -%}{%- assign colour_param = filter.values[0].param_name -%}{%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        <div class="kl-fg is-open" data-fg>
          <button class="kl-fg__head" type="button" onclick="this.closest('[data-fg]').classList.toggle('is-open')">
            <svg class="kl-fg__chevron" width="10" height="7" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Colour</span>
          </button>
          <div class="kl-fg__body">
            <div class="kl-swatch-list">
              {%- assign static_colours = 'Cream,Red,Grey,Black,Brown' | split: ',' -%}
              {%- for colour in static_colours -%}
                {%- assign col_param = colour | url_encode -%}
                {%- assign col_active = false -%}
                {%- if request.query_string contains col_param -%}{%- assign col_active = true -%}{%- endif -%}
                <label class="kl-swatch-item">
                  <input type="checkbox"
                    name="{{ colour_param }}"
                    value="{{ colour }}"
                    {% if col_active %}checked{% endif %}
                    form="kl-form-sidebar"
                    onchange="document.getElementById('kl-form-sidebar').submit()">
                  <span class="kl-swatch-dot{% if col_active %} is-checked{% endif %}" style="background:{%- render 'swatch-color', name: colour -%};"></span>
                  <span class="kl-swatch-name">{{ colour }}</span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        </div>

        <form id="kl-form-sidebar" method="get" action="{{ collection.url }}">
          <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
        </form>
      </aside>

      {%- comment -%} ---- RIGHT CONTENT ---------------------------------------- {%- endcomment -%}
      <div class="kl-col-content">

        {%- comment -%} Collection title + description {%- endcomment -%}
        <div class="kl-col-head">
          <h1 class="kl-col-title">{{ collection.title }}</h1>
          {%- assign is_divan = false -%}
          {%- if collection.handle == 'divan-beds' or collection.handle == 'divan-bed' or collection.handle contains 'divan' -%}
            {%- assign is_divan = true -%}
          {%- endif -%}
          {%- if is_divan -%}
            <div class="kl-col-desc">Looking for a chic and functional bed? Look no further. Our divan beds feature a solid platform-top base with a beautifully designed headboard suitable for every bedroom. The clever built-in storage drawers are perfect for tucking away your collections, spare blankets — or that secret stash of late-night snacks. Robust, practical, and space-saving, our beds are built to last without taking over your room. Explore our wide range of enticing colours and sizes and find the one made for you.</div>
          {%- elsif collection.handle contains 'upholstered' -%}
            <div class="kl-col-desc">Transform your bedroom with a Klawford upholstered bed — fully padded and fabric-finished from headboard to base for a look that's as luxurious as it is comfortable. Choose from plush velvets, rich chenilles, and durable weaves in a wide range of colours, all with optional built-in storage drawers to make the most of your space. Available in every standard UK size, with button-stud, wingback, and panel headboard styles to suit your taste. Handmade in the UK and built to last, each bed is designed to make your bedroom feel like a retreat.</div>
          {%- elsif collection.description != blank -%}
            <div class="kl-col-desc">{{ collection.description | strip_html }}</div>
          {%- endif -%}
        </div>

        {%- comment -%} Sort bar {%- endcomment -%}
        <div class="kl-sort-bar">
          {%- if active_filter_count > 0 -%}
            <div class="kl-chips" role="list" aria-label="Active filters">
              {%- for filter in collection.active_filters -%}
                <a href="{{ filter.url_to_remove }}" class="kl-chip" role="listitem">
                  {{ filter.label }}: {{ filter.value }}
                  <svg width="8" height="8" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                    <path d="M2 2l6 6M8 2L2 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </a>
              {%- endfor -%}
              <a href="{{ collection.url }}" class="kl-chip kl-chip--clear">Clear all</a>
            </div>
          {%- endif -%}
          <div class="kl-sort">
            <label class="kl-sort__label" for="kl-sort-select">Sort by</label>
            <select id="kl-sort-select" aria-label="Sort products"
              onchange="window.location.href='{{ collection.url }}?sort_by=' + this.value">
              {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
              {%- endfor -%}
            </select>
          </div>
        </div>

        {%- comment -%} Product grid {%- endcomment -%}
        {%- if collection.products.size > 0 -%}
          <div class="kl-grid">
            {%- for product in collection.products -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          </div>

          {%- comment -%} Pagination {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <nav class="kl-pagination" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="kl-pagination__btn kl-pagination__btn--prev" aria-label="Previous page">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              {%- endif -%}
              <div class="kl-pagination__pages">
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="kl-pagination__page">{{ part.title }}</a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span class="kl-pagination__page is-current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="kl-pagination__ellipsis">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="kl-pagination__btn kl-pagination__btn--next" aria-label="Next page">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        {%- else -%}
          <div class="kl-no-results">
            <p>No products found matching your selection.</p>
            {%- if active_filter_count > 0 -%}
              <a href="{{ collection.url }}" class="btn btn--primary" style="margin-top:16px;">Clear filters</a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} SEO content — always visible below grid {%- endcomment -%}
        {%- if section.settings.show_seo_content and section.settings.seo_content != blank -%}
          <div class="kl-seo">
            <div class="kl-seo__inner rte">
              {{ section.settings.seo_content }}
            </div>
          </div>
        {%- elsif collection.handle contains 'upholstered' -%}
          <div class="kl-seo">
            <div class="kl-seo__inner rte">
              <h3>What is an upholstered bed?</h3><p>An upholstered bed is a bed frame fully wrapped in fabric — velvet, chenille, or a durable weave — and padded from headboard to base. Unlike a wooden or metal frame, the soft finish makes it a natural bedroom centrepiece, and the padded headboard gives you something comfortable to lean against when reading or watching TV.</p>
              <h3>What are the benefits of an upholstered bed?</h3><p>Upholstered beds add warmth and texture that hard-frame beds simply can't match — making them one of the most popular choices for a master bedroom. The padded finish is softer to the touch, kinder on corners, and acts as a natural insulator, so your room feels warmer and quieter. With a wide range of fabrics, colours, and headboard styles, they're also one of the most customisable beds you can buy.</p>
              <h3>Does an upholstered bed come with a mattress?</h3><p>It depends on the listing — some of our upholstered beds are sold as a complete bed-and-mattress bundle, while others let you choose the frame on its own so you can pair it with a mattress you already own or pick one separately. Check the product options on each listing to see what's included.</p>
              <h3>What fabric and colour options are there?</h3><p>Our upholstered range comes in a selection of fabrics and colourways, from plush velvets to more practical weaves, so you can match the bed to the rest of your room. Each fabric is available in multiple colours — from neutral creams and warm greys to bold blacks and rich jewel tones.</p>
              <h3>What does a wingback headboard add?</h3><p>A wingback headboard has panels that angle out at the sides, creating a more framed, cocooned look and giving you something to lean against side-on. It's more than just a styling choice — it makes the bed feel like a private retreat within the room, adding a sense of enclosure that a flat headboard doesn't give you.</p>
              <h3>Wingback vs. panel headboard — what's the difference?</h3><p>A wingback headboard features angled side panels for a dramatic, hotel-suite look. A panel headboard is flat and neatly stitched — cleaner and more understated, and usually a little more affordable. Both styles are available across our full fabric and colour range.</p>
              <h3>Do upholstered beds come with storage?</h3><p>Yes — most of our upholstered beds are available with optional built-in drawers, typically two or four, positioned on either side of the base for easy everyday access. Ottoman-style options are also available, where the entire base lifts on gas-lift pistons to reveal a large under-bed compartment — ideal for bedding, pillows, and seasonal items.</p>
              <h3>Are upholstered beds easy to assemble?</h3><p>Yes — our upholstered beds are designed for straightforward home assembly with basic tools, and the headboard typically brackets on separately. Full step-by-step instructions and all necessary fixings are included with every order.</p>
            </div>
          </div>
        {%- endif -%}

      </div>{%- comment -%}/.kl-col-content{%- endcomment -%}

    </div>{%- comment -%}/.kl-col-layout{%- endcomment -%}

  </div>
</div>

{%- comment -%} ================================================================
    REVIEWS SECTION (Trustpilot carousel concept)
    ================================================================ {%- endcomment -%}
{%- if section.settings.show_reviews -%}
<div class="kl-reviews">
  <div class="container">
    <h2 class="kl-reviews__heading">{{ section.settings.reviews_heading | default: 'What Our Customers Say' }}</h2>

    {%- if section.settings.trustpilot_widget != blank -%}
      <div class="kl-reviews__widget">{{ section.settings.trustpilot_widget }}</div>
    {%- else -%}

      {%- comment -%} Visual carousel shell — replace with real Trustpilot widget later {%- endcomment -%}
      <div class="kl-reviews__carousel" id="kl-rev-track-wrap">
        <button class="kl-reviews__arrow kl-reviews__arrow--prev" id="kl-rev-prev" aria-label="Previous reviews" type="button">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div class="kl-reviews__track-wrap">
          <div class="kl-reviews__track" id="kl-rev-track">
            {%- assign review_titles = 'Absolutely love my bed!,Incredible quality,Fast delivery & great service,Worth every penny,Stunning craftsmanship,Best sleep of my life,Highly recommend Klawford' | split: ',' -%}
            {%- assign review_bodies = 'The quality is outstanding and it looks beautiful in our bedroom. Could not be happier with our purchase.,We ordered a divan bed and it arrived perfectly packaged. The build quality is excellent.,Delivered on time and the team were brilliant. The bed is solid and incredibly comfortable.,We were hesitant to order online but Klawford made the whole process so easy. Love it!,The finish on this bed is incredible — it looks far more expensive than it was. Great value.,We have slept so much better since getting our new Klawford bed. Genuinely amazing quality.,From ordering to delivery everything was perfect. The bed is even better in person.' | split: ',' -%}
            {%- assign review_authors = 'Sarah M.,James T.,Emily R.,David H.,Charlotte B.,Michael W.,Olivia P.' | split: ',' -%}
            {%- for i in (0..6) -%}
              <div class="kl-review-card">
                <div class="kl-review-card__stars">
                  <svg width="80" height="16" viewBox="0 0 80 16" fill="none" aria-label="5 stars">
                    {%- for s in (0..4) -%}
                      {%- assign sx = s | times: 16 -%}
                      <rect x="{{ sx }}" y="0" width="14" height="14" rx="2" fill="#00B67A"/>
                      <path d="M{{ sx | plus: 7 }} 2l1.2 2.5 2.8.4-2 2 .5 2.8-2.5-1.3-2.5 1.3.5-2.8-2-2 2.8-.4z" fill="#fff"/>
