<div class="collection-main">
  <div class="container">
    <div class="collection-header">
      <h1 class="collection-header__title">{{ blog.title }}</h1>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap-base);">
      {%- for article in blog.articles -%}
        <article style="border-radius:var(--radius-base);overflow:hidden;background:var(--clr-white);box-shadow:var(--shadow-sm);">
          {%- if article.image -%}
            <a href="{{ article.url }}">
              <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy" style="width:100%;aspect-ratio:16/9;object-fit:cover;">
            </a>
          {%- endif -%}
          <div style="padding:20px;">
            <p style="font-size:var(--fs-xs);color:var(--clr-gray-dusty);margin-bottom:8px;">{{ article.published_at | date: "%B %d, %Y" }}</p>
            <h2 style="font-family:var(--ff-primary);font-size:var(--fs-lg);margin-bottom:10px;"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p style="font-size:var(--fs-sm);color:var(--clr-text-light);">{{ article.excerpt | strip_html | truncate: 120 }}</p>
            <a href="{{ article.url }}" class="btn btn--outline btn--sm" style="margin-top:16px;">Read More</a>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
