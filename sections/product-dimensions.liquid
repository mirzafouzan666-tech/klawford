<section class="product-dimensions">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading | default: 'Dimensions' }}</h2>

    <div class="dimensions-tabs" role="tablist">
      <button class="dimensions-tab active" role="tab" onclick="switchDimTab(this,'product')" aria-selected="true">Product Dimensions</button>
      <button class="dimensions-tab" role="tab" onclick="switchDimTab(this,'package')" aria-selected="false">Package Dimensions</button>
    </div>

    <div class="dimensions-content">
      <div class="dimensions-panel" id="dim-product">
        <div class="dimensions-grid">
          <div class="dimensions-illustration">
            {%- if section.settings.product_image != blank -%}
              <img
                src="{{ section.settings.product_image | image_url: width: 600 }}"
                alt="Product dimensions diagram"
                loading="lazy"
                width="600"
                height="400">
            {%- else -%}
              <div class="dimensions-placeholder">
                <svg viewBox="0 0 260 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="30" y="70" width="200" height="80" rx="4" stroke="#7F285B" stroke-width="1.5" fill="#F2E8E0"/>
                  <rect x="50" y="50" width="160" height="25" rx="2" stroke="#7F285B" stroke-width="1.5" fill="#fcf4ee"/>
                  <rect x="22" y="140" width="10" height="28" rx="2" stroke="#7F285B" stroke-width="1.5" fill="#F2E8E0"/>
                  <rect x="228" y="140" width="10" height="28" rx="2" stroke="#7F285B" stroke-width="1.5" fill="#F2E8E0"/>
                  <line x1="30" y1="175" x2="230" y2="175" stroke="#989898" stroke-width="1" stroke-dasharray="4 3"/>
                  <text x="130" y="173" text-anchor="middle" font-size="10" fill="#474546" font-family="Nunito Sans">Width</text>
                  <line x1="240" y1="70" x2="240" y2="150" stroke="#989898" stroke-width="1" stroke-dasharray="4 3"/>
                  <text x="252" y="113" text-anchor="middle" font-size="10" fill="#474546" font-family="Nunito Sans">Height</text>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <div class="dimensions-table-wrap">
            <p class="dimensions-product-name">{{ product.title }}</p>
            {%- if section.settings.headboard_note != blank -%}
              <p class="dimensions-note">{{ section.settings.headboard_note }}</p>
            {%- endif -%}
            <table class="dimensions-table">
              <thead>
                <tr>
                  <th>Size</th>
                  <th>Length</th>
                  <th>Width</th>
                </tr>
              </thead>
              <tbody>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'dimension_row' -%}
                    <tr {{ block.shopify_attributes }}>
                      <td>{{ block.settings.size }}</td>
                      <td>{{ block.settings.length }}</td>
                      <td>{{ block.settings.width }}</td>
                    </tr>
                  {%- endif -%}
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="dimensions-panel" id="dim-package" style="display:none;">
        <div class="dimensions-grid">
          <div class="dimensions-illustration">
            <div class="dimensions-placeholder" style="background:var(--clr-wild-sand);">
              <svg viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="20" y="30" width="160" height="110" rx="4" stroke="#7F285B" stroke-width="1.5" fill="#F2E8E0"/>
                <path d="M20 60h160M100 30v110" stroke="#7F285B" stroke-width="1" stroke-dasharray="4 3"/>
                <text x="100" y="20" text-anchor="middle" font-size="11" fill="#474546" font-family="Nunito Sans">Package</text>
              </svg>
            </div>
          </div>
          <div class="dimensions-table-wrap">
            <p class="dimensions-product-name">{{ product.title }} — Packaging</p>
            <table class="dimensions-table">
              <thead><tr><th>Size</th><th>Length</th><th>Width</th></tr></thead>
              <tbody>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'package_row' -%}
                    <tr {{ block.shopify_attributes }}>
                      <td>{{ block.settings.size }}</td>
                      <td>{{ block.settings.length }}</td>
                      <td>{{ block.settings.width }}</td>
                    </tr>
                  {%- endif -%}
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function switchDimTab(btn,panel){
  document.querySelectorAll('.dimensions-tab').forEach(function(t){t.classList.remove('active');t.setAttribute('aria-selected','false')});
  document.querySelectorAll('.dimensions-panel').forEach(function(p){p.style.display='none'});
  btn.classList.add('active');
  btn.setAttribute('aria-selected','true');
  var el=document.getElementById('dim-'+panel);
  if(el)el.style.display='block';
}
</script>

{% schema %}
{
  "name": "Product Dimensions",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Dimensions" },
    { "type": "image_picker", "id": "product_image", "label": "Dimension diagram image" },
    { "type": "text", "id": "headboard_note", "label": "Headboard note", "default": "Small Divan Standing Headboard" }
  ],
  "blocks": [
    {
      "type": "dimension_row",
      "name": "Product Dimension Row",
      "settings": [
        { "type": "text", "id": "size", "label": "Size", "default": "3ft Single" },
        { "type": "text", "id": "length", "label": "Length", "default": "190 cm" },
        { "type": "text", "id": "width", "label": "Width", "default": "90 cm" }
      ]
    },
    {
      "type": "package_row",
      "name": "Package Dimension Row",
      "settings": [
        { "type": "text", "id": "size", "label": "Size", "default": "3ft Single" },
        { "type": "text", "id": "length", "label": "Length", "default": "100 cm" },
        { "type": "text", "id": "width", "label": "Width", "default": "48 cm" }
      ]
    }
  ],
  "presets": [{ "name": "Product Dimensions", "blocks": [
    { "type": "dimension_row", "settings": { "size": "3ft Single", "length": "190 cm", "width": "90 cm" } },
    { "type": "dimension_row", "settings": { "size": "4ft Small Double", "length": "190 cm", "width": "120 cm" } },
    { "type": "dimension_row", "settings": { "size": "4ft 6 Double", "length": "190 cm", "width": "135 cm" } },
    { "type": "dimension_row", "settings": { "size": "5ft King", "length": "200 cm", "width": "150 cm" } },
    { "type": "dimension_row", "settings": { "size": "6ft Super King", "length": "200 cm", "width": "180 cm" } },
    { "type": "package_row", "settings": { "size": "3ft Single", "length": "100 cm", "width": "48 cm" } },
    { "type": "package_row", "settings": { "size": "4ft Small Double", "length": "100 cm", "width": "62 cm" } },
    { "type": "package_row", "settings": { "size": "4ft 6 Double", "length": "100 cm", "width": "70 cm" } },
    { "type": "package_row", "settings": { "size": "5ft King", "length": "106 cm", "width": "78 cm" } },
    { "type": "package_row", "settings": { "size": "6ft Super King", "length": "106 cm", "width": "92 cm" } }
  ] }]
}
{% endschema %}
