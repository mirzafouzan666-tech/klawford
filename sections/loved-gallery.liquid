<section class="loved-gallery">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
  </div>

  <!-- Scrollable gallery (full-bleed inside container) -->
  <div class="container" style="padding-right:0;overflow:hidden;">
    <div class="loved-gallery__track" id="gallery-track" aria-label="Customer photos gallery">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' -%}
          <div class="gallery-item" {{ block.shopify_attributes }}>
            <div class="gallery-item__img">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 480 }}"
                  srcset="{{ block.settings.image | image_url: width: 320 }} 320w,
                          {{ block.settings.image | image_url: width: 480 }} 480w"
                  sizes="240px"
                  alt="{{ block.settings.alt | escape | default: 'Customer photo' }}"
                  loading="lazy"
                  width="240"
                  height="320">
              {%- else -%}
                {%- if forloop.index0 == 0 -%}
                  <div class="gallery-item__bg" style="background-image: url('{{ 'klawford_trending_sage_green_upholstered_bed.jpg' | asset_url }}');"></div>
                {%- else -%}
                  {%- assign fallback_ids = 'photo-1631049307264-da0ec9d70304,photo-1505693416388-ac5ce068fe85,photo-1493663284031-b7e3aefcae8e,photo-1560448204-603b3fc33ddc,photo-1616046229478-9901c5536a45' | split: ',' -%}
                  {%- assign fb_idx = forloop.index0 | minus: 1 -%}
                  {%- assign fb_id = fallback_ids[fb_idx] | default: 'photo-1505693416388-ac5ce068fe85' -%}
                  <div class="gallery-item__bg" style="background-image: url('https://images.unsplash.com/{{ fb_id }}?auto=format&fit=crop&w=480&q=85');"></div>
                {%- endif -%}
              {%- endif -%}
            </div>
            {%- if block.settings.show_play -%}
              <div class="gallery-item__play" aria-hidden="true">
                <div class="gallery-play-btn">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M5 3l11 6-11 6V3z" fill="var(--clr-secondary)" stroke="var(--clr-secondary)" stroke-width="1" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <div class="gallery-item">
          <div class="gallery-item__img">
            <div class="gallery-item__bg" style="background-image: url('{{ 'klawford_trending_sage_green_upholstered_bed.jpg' | asset_url }}');"></div>
          </div>
        </div>
        {%- assign gallery_imgs = 'photo-1631049307264-da0ec9d70304,photo-1505693416388-ac5ce068fe85,photo-1493663284031-b7e3aefcae8e,photo-1560448204-603b3fc33ddc,photo-1616046229478-9901c5536a45' | split: ',' -%}
        {%- for img_id in gallery_imgs -%}
          <div class="gallery-item">
            <div class="gallery-item__img">
              <div class="gallery-item__bg" style="background-image: url('https://images.unsplash.com/{{ img_id }}?auto=format&fit=crop&w=480&q=85');"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <!-- Navigation buttons -->
  <div class="container">
    <div class="loved-gallery__controls">
      <button class="gallery-nav-btn" data-dir="prev" aria-label="Previous photos">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="gallery-nav-btn" data-dir="next" aria-label="Next photos">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Loved Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Loved in Homes Just Like Yours"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "default": "Customer home photo"
        },
        {
          "type": "checkbox",
          "id": "show_play",
          "label": "Show play button overlay",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Loved Gallery",
      "blocks": [
        { "type": "image", "settings": { "show_play": true } },
        { "type": "image", "settings": { "show_play": true } },
        { "type": "image", "settings": { "show_play": true } },
        { "type": "image", "settings": { "show_play": true } },
        { "type": "image", "settings": { "show_play": false } },
        { "type": "image", "settings": { "show_play": false } }
      ]
    }
  ]
}
{% endschema %}
