<section class="product-services">
  <div class="container">
    <div class="product-services__grid">
      <div class="product-services__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 700 }}"
            alt="{{ section.settings.image.alt | escape | default: 'Sleep specialist' }}"
            loading="lazy"
            width="700"
            height="500">
        {%- else -%}
          <div style="aspect-ratio:4/3;background:linear-gradient(135deg,#e0d4c8,#c8bcb0);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="product-services__text">
        <h2 class="product-services__heading">{{ section.settings.heading | default: 'Sleep Specialists At Your Service!' }}</h2>

        <ul class="product-services__list">
          {%- for block in section.blocks -%}
            <li class="product-services__item" {{ block.shopify_attributes }}>
              <div class="product-services__item-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4"/><path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <h3 class="product-services__item-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="product-services__item-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.settings.show_atc -%}
          <div style="margin-top:var(--gap-lg);">
            <a href="#product-form" class="btn btn--primary btn--lg" onclick="window.scrollTo({top:0,behavior:'smooth'})">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 1h2.5l1.7 8.6a2 2 0 0 0 2 1.4h7.3a2 2 0 0 0 2-1.6L17.5 4H4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="15.5" r="1.5" stroke="currentColor" stroke-width="1.4"/><circle cx="13.5" cy="15.5" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
              {{ section.settings.atc_label | default: 'Add to Basket' }}
            </a>
            <div style="margin-top:14px;">
              {%- render 'payment-icons' -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Services",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sleep Specialists At Your Service!" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "show_atc", "label": "Show Add to Basket button", "default": true },
    { "type": "text", "id": "atc_label", "label": "Button label", "default": "Add to Basket" }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Delivered to Your Room" },
        { "type": "text", "id": "description", "label": "Description", "default": "Our 2-man delivery team will bring your order straight to your room of choice — no extra charge." }
      ]
    }
  ],
  "presets": [{ "name": "Product Services", "blocks": [
    { "type": "service", "settings": { "title": "Delivered to Your Room", "description": "Our 2-man delivery team will bring your order straight to your room of choice at no extra charge." } },
    { "type": "service", "settings": { "title": "Stress-Free Assembly", "description": "Your free team of experts will assemble your new bed set in as little as 15 minutes so all you have to do is enjoy it." } },
    { "type": "service", "settings": { "title": "We're Just a Phone Call Away", "description": "Got questions or need advice? Our sleep specialists are ready to help. Call us at 0800 000 0000 and we'll be happy to assist!" } }
  ] }]
}
{% endschema %}
