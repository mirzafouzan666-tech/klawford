<section class="product-features-section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading | default: 'Why Choose A Klawford Divan Bed?' }}</h2>
  </div>
  <div class="product-features-grid">
    {%- for block in section.blocks -%}
      {%- assign is_even = forloop.index | modulo: 2 -%}
      <div class="product-feature-row {% if is_even == 0 %}product-feature-row--reverse{% endif %}" {{ block.shopify_attributes }}>
        <div class="product-feature-row__image">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 800 }} 800w"
              sizes="50vw"
              alt="{{ block.settings.image.alt | escape | default: block.settings.title }}"
              loading="lazy"
              width="800"
              height="600"
              style="width:100%;height:100%;object-fit:cover;display:block;">
          {%- elsif block.settings.image_src != blank -%}
            <img
              src="{{ block.settings.image_src }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
              width="800"
              height="600"
              style="width:100%;height:100%;object-fit:cover;display:block;">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="product-feature-row__text">
          <h3 class="product-feature-row__title">{{ block.settings.title }}</h3>
          <div class="product-feature-row__desc rte">{{ block.settings.description }}</div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Features",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Choose A Klawford Divan Bed?" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_src", "label": "Image URL (fallback)" },
        { "type": "text", "id": "title", "label": "Title", "default": "60 Night Risk-Free Trial" },
        { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Our beds are crafted with exceptional quality, and we're sure you'll love your Klawford bed. However, if you're not completely satisfied with your purchase within the first 60 nights, simply contact us for a hassle-free return or swap.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "Product Features", "blocks": [
    { "type": "feature", "settings": { "title": "60 Night Risk-Free Trial", "description": "<p>Our beds are crafted with exceptional quality, and we're sure you'll love your Klawford bed. However, if you're not completely satisfied within the first 60 nights, simply contact us for a hassle-free return or swap.</p>" } },
    { "type": "feature", "settings": { "title": "Extra Storage Option For More Space", "description": "<p>Make the most of your space with Klawford Divan Beds. Choose from our fantastic range of storage options to keep your bedroom organised and clutter-free.</p>" } },
    { "type": "feature", "settings": { "title": "Sustainably Sourced & Handmade in The UK", "description": "<p>Every Klawford bed is made with the finest components from sustainably sourced materials, ensuring longevity, comfort, and eco-friendly design.</p>" } },
    { "type": "feature", "settings": { "title": "Customisable & Beautiful Headboards", "description": "<p>Every Klawford Divan Bed comes with a stunning headboard designed to complement your bed perfectly. Every headboard is removable — more than that — integrate it into your bedroom.</p>" } },
    { "type": "feature", "settings": { "title": "Handle Extreme Weight With a Reinforced Base", "description": "<p>Our divan bed base is built to last and designed for maximum durability. The reinforced base is perfect for couples or families, with an exceptional weight tolerance able to support all types of sleepers.</p>" } }
  ] }]
}
{% endschema %}
