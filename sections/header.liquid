<!-- Announcement bar -->
{%- if section.settings.show_announcement -%}
<div class="promo-bar" aria-label="Promotional announcement">
  <div class="promo-bar__text">
    <span>{{ section.settings.announcement_text | default: "TODAY'S DAILY DEAL - EXTRA 25% OFF - ENDS IN:" }}</span>
    <span class="promo-bar__countdown-group">
      <span class="promo-bar__countdown promo-countdown__time" data-unit="h">00 h</span>
      <span class="promo-bar__countdown promo-countdown__time" data-unit="m">00 m</span>
      <span class="promo-bar__countdown promo-countdown__time" data-unit="s">00 s</span>
    </span>
    <span>USE CODE</span>
    <button type="button" class="promo-bar__code" id="promo-code-copy" data-code="{{ section.settings.promo_code | default: "EXTRA25" }}" aria-label="Copy promo code">
      {{ section.settings.promo_code | default: "EXTRA25" }}
      <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="4" y="4" width="9" height="9" rx="1.2" stroke="currentColor" stroke-width="1.3"/><path d="M10 4V2.5A1.2 1.2 0 0 0 8.8 1.3H2.2A1.2 1.2 0 0 0 1 2.5v6.6A1.2 1.2 0 0 0 2.2 10.3H4" stroke="currentColor" stroke-width="1.3"/></svg>
    </button>
  </div>
</div>
{%- endif -%}

<header class="site-header" id="site-header" role="banner">

  <!-- Top row: search | logo | actions -->
  <div class="header-top">
    <div class="container">
      <div class="header-top__inner">

        <!-- Search trigger -->
        <div class="header-search">
          <button class="header-search-trigger" id="search-open" aria-label="Open search" aria-expanded="false">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="6.5" cy="6.5" r="4.75" stroke="currentColor" stroke-width="1.4"/>
              <path d="m10 10 3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <span>Search products</span>
          </button>
        </div>

        <!-- Logo -->
        <div class="header-logo">
          <a href="/" aria-label="{{ shop.name }} home">
            {%- if section.settings.logo != blank -%}
              <img
                src="{{ section.settings.logo | image_url: width: 320 }}"
                alt="{{ shop.name }}"
                class="header-logo__img"
                width="{{ section.settings.logo.width }}"
                height="{{ section.settings.logo.height }}"
                loading="eager">
            {%- else -%}
              <span class="header-logo__text">{{ shop.name }}</span>
            {%- endif -%}
          </a>
        </div>

        <!-- Actions -->
        <div class="header-actions">
          <button class="header-action" id="cart-open-btn" data-cart-open aria-label="Open cart">
            <span class="header-action__icon-wrap">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.4"/>
                <path d="M16 10a5 5 0 0 1-10 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="header-action__badge header-cart-count" id="header-cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %}>
                {{ cart.item_count }}
              </span>
            </span>
            <span class="header-action__label">My Basket</span>
          </button>

          <!-- Mobile menu button -->
          <button class="header-mobile-btn" id="mobile-menu-open" aria-label="Open navigation menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- Desktop navigation -->
  <nav class="header-nav" aria-label="Main navigation">
    <div class="container">
      <ul class="header-nav__list" role="list">
        {%- for link in linklists[section.settings.menu].links -%}
          <li class="header-nav__item {% if link.active %}is-active{% endif %}">
            <a href="{{ link.url }}" class="header-nav__link" {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title }}
              {%- if link.links.size > 0 -%}
                <svg width="10" height="7" viewBox="0 0 10 7" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <div class="header-dropdown">
                <ul role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a href="{{ child.url }}" {% if child.active %}aria-current="page"{% endif %}>{{ child.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </nav>

  <!-- Benefits strip -->
  {%- if section.settings.show_benefits -%}
  <div class="header-benefits">
    <div class="container">
      <div class="header-benefits__inner">
        <span class="header-benefit">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {{ section.settings.benefit_1 | default: "60 Night Risk-Free Trial" }}
        </span>
        <span class="header-benefit">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1" y="4" width="12" height="7" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M4 4V3a3 3 0 0 1 6 0v1" stroke="currentColor" stroke-width="1.3"/></svg>
          {{ section.settings.benefit_2 | default: "Fast Free delivery" }}
        </span>
        <span class="header-benefit">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1l1.5 3 3.5.5-2.5 2.5.6 3.5L7 9l-3.1 1.5.6-3.5L2 4.5l3.5-.5L7 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
          {{ section.settings.benefit_3 | default: "Handmade In UK" }}
        </span>
        <span class="header-benefit">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1" y="3" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M1 6h12" stroke="currentColor" stroke-width="1.3"/></svg>
          {{ section.settings.benefit_4 | default: "Pay Monthly" }}
        </span>
      </div>
    </div>
  </div>
  {%- endif -%}

</header>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="mobile-menu__header">
    <a href="/" class="header-logo__text" aria-label="{{ shop.name }} home">{{ shop.name }}</a>
    <button class="mobile-menu__close" id="mobile-menu-close" aria-label="Close navigation menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M17 5L5 17M5 5l12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <ul class="mobile-menu__list" role="list">
    {%- for link in linklists[section.settings.menu].links -%}
      <li>
        <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
        {%- if link.links.size > 0 -%}
          <ul class="mobile-menu__sub" role="list">
            {%- for child in link.links -%}
              <li><a href="{{ child.url }}">{{ child.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</div>
<div class="mobile-overlay" id="mobile-overlay"></div>

<script>
  // Wire up mobile menu (inline so it works before theme.js loads)
  (function() {
    var open    = document.getElementById('mobile-menu-open');
    var close   = document.getElementById('mobile-menu-close');
    var overlay = document.getElementById('mobile-overlay');
    var menu    = document.getElementById('mobile-menu');
    var cart    = document.getElementById('cart-open-btn');
    function openM()  { menu.classList.add('is-open'); overlay.classList.add('is-visible'); document.body.style.overflow='hidden'; }
    function closeM() { menu.classList.remove('is-open'); overlay.classList.remove('is-visible'); document.body.style.overflow=''; }
    if (open)    open.addEventListener('click', openM);
    if (close)   close.addEventListener('click', closeM);
    if (overlay) overlay.addEventListener('click', closeM);
    // Cart drawer open
    if (cart) cart.addEventListener('click', function() {
      var drawer = document.getElementById('cart-drawer');
      if (drawer) { drawer.classList.add('is-open'); drawer.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    });
    // Search
    var searchBtn = document.getElementById('search-open');
    var searchOverlay = document.getElementById('search-overlay');
    if (searchBtn && searchOverlay) {
      searchBtn.addEventListener('click', function() {
        searchOverlay.classList.add('is-open');
        searchOverlay.setAttribute('aria-hidden','false');
        document.body.style.overflow='hidden';
        setTimeout(function(){ document.getElementById('search-input')?.focus(); }, 280);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Recommended: 320 x 80px PNG with transparent background"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 280,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 160
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "SUMMER SALE — EXTRA 30% OFF SITEWIDE — ENDS SOON:" },
    { "type": "text", "id": "promo_code", "label": "Promo code", "default": "EXTRA30" },
    {
      "type": "header",
      "content": "Benefits Strip"
    },
    { "type": "checkbox", "id": "show_benefits", "label": "Show benefits strip", "default": true },
    { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "60 Night Risk-Free Trial" },
    { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "Fast Free delivery" },
    { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "Handmade In UK" },
    { "type": "text", "id": "benefit_4", "label": "Benefit 4", "default": "Pay Monthly" }
  ]
}
{% endschema %}
