<section class="product-finance">
  <div class="container">
    <div class="product-finance__grid">
      <div class="product-finance__text">
        <div class="product-finance__badge">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="1" y="4" width="16" height="11" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M1 8h16" stroke="currentColor" stroke-width="1.4"/><path d="M4 12h3M9 12h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          {{ section.settings.provider_label | default: '0% INTEREST-FREE INSTALLMENTS' }}
        </div>
        <h2 class="product-finance__heading">{{ section.settings.heading | default: 'Shop Now, Pay Later' }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="product-finance__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}

        <ul class="product-finance__points">
          {%- for block in section.blocks -%}
            <li class="product-finance__point" {{ block.shopify_attributes }}>
              <div class="product-finance__point-icon">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.description != blank -%}
                  <p>{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="product-finance__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 700 }}"
            alt="{{ section.settings.image.alt | escape | default: 'Finance option' }}"
            loading="lazy"
            width="700"
            height="500">
        {%- else -%}
          <div style="aspect-ratio:4/3;background:linear-gradient(135deg,#e8d8c8,#d0c0b0);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Finance",
  "settings": [
    { "type": "text", "id": "provider_label", "label": "Provider badge label", "default": "0% INTEREST-FREE INSTALLMENTS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop Now, Pay Later" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Split the cost of your order into easy monthly instalments." },
    { "type": "image_picker", "id": "image", "label": "Right-side image" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Up to 12 Monthly Instalments" },
        { "type": "text", "id": "description", "label": "Description", "default": "Spread the cost of your order over up to 12 equal monthly payments." }
      ]
    }
  ],
  "presets": [{ "name": "Product Finance", "blocks": [
    { "type": "point", "settings": { "title": "Up to 12 Monthly Instalments", "description": "Spread the cost of your order over up to 12 equal monthly payments." } },
    { "type": "point", "settings": { "title": "Zero Interest Rate", "description": "Pay absolutely nothing extra — 0% interest for the full term of your plan." } },
    { "type": "point", "settings": { "title": "No Early Repayment Charges", "description": "Want to pay it off sooner? No problem — there are no fees when your balance is paid early." } }
  ] }]
}
{% endschema %}
