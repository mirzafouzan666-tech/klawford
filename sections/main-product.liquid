<div class="product-main">
  <div class="container">

    <nav class="product-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M3 1l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M3 1l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      {%- endif -%}
      <span>{{ product.title }}</span>
    </nav>

    <div class="product-main__grid">

      {%- comment -%}---- GALLERY ----{%- endcomment -%}
      <div class="product-gallery">

        <div class="product-gallery__main" id="product-gallery-main">
          {%- if product.featured_image -%}
            <img
              id="product-main-img"
              src="{{ product.featured_image | image_url: width: 900 }}"
              srcset="{{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 900 }} 900w,
                      {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="900"
              height="900"
              loading="eager"
              fetchpriority="high">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <span class="product-gallery__badge" style="background:var(--clr-green);display:inline-flex;align-items:center;gap:6px;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M7 4v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            60 Night Risk Free Trial
          </span>
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs" id="product-thumbs">
            {%- for image in product.images -%}
              {%- assign img_colour = image.alt | split: '–' | last | strip | downcase -%}
              <button
                class="product-gallery__thumb {% if forloop.first %}active{% endif %}"
                type="button"
                data-src="{{ image | image_url: width: 900 }}"
                data-colour="{{ img_colour }}"
                data-img-id="{{ image.id }}"
                aria-label="View image {{ forloop.index }}">
                <img
                  src="{{ image | image_url: width: 160 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="80"
                  height="80"
                  loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_upsell -%}
          <div class="product-upsell">
            {%- if section.settings.upsell_1_label != blank -%}
              <div class="product-upsell-card">
                <div class="product-upsell-card__icons">
                  <svg width="28" height="22" viewBox="0 0 28 22" fill="none"><rect x="1" y="8" width="22" height="10" rx="2" stroke="currentColor" stroke-width="1.4"/><rect x="4" y="5" width="16" height="5" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M2 18v3M22 18v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                  <span style="font-size:18px;color:var(--clr-ash);font-weight:300;">+</span>
                  <svg width="28" height="16" viewBox="0 0 28 16" fill="none"><rect x="1" y="1" width="26" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M5 6h18M5 10h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                </div>
                <div class="product-upsell-card__body">
                  <p class="product-upsell-card__title">{{ section.settings.upsell_1_label }}</p>
                </div>
                <div class="product-upsell-card__action">
                  <button type="button" class="product-upsell-card__link" data-open-mattress>
                    {{ section.settings.upsell_2_label | default: 'Choose Mattress' }}
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 1l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                  </button>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.show_assembly -%}
              <div class="product-upsell-card">
                <div class="product-upsell-card__icons">
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M6 22l2-2 2.5 2.5 10-14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="20" cy="8" r="5" stroke="currentColor" stroke-width="1.4"/><path d="M17 8h6M20 5v6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                </div>
                <div class="product-upsell-card__body">
                  <p class="product-upsell-card__title">{{ section.settings.assembly_label | default: 'Professional Assembly' }}</p>
                  <p class="product-upsell-card__desc">{{ section.settings.assembly_desc | default: 'Our team will deliver your bed and mattress to your room and professionally assemble it for you.' }}</p>
                </div>
                <div class="product-upsell-card__action">
                  <span class="product-upsell-card__price">{{ section.settings.assembly_price | default: '£39.99' }}</span>
                  <button type="button" class="btn btn--primary product-upsell-card__add" data-assembly-add>Add</button>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%}---- PRODUCT INFO ----{%- endcomment -%}
      <div class="product-info" id="product-info">

        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-info__title">{{ product.title }}</h1>

        {%- unless product.has_only_default_variant -%}
          <p class="product-info__subtitle" id="product-variant-subtitle">
            {{- product.selected_or_first_available_variant.title | replace: ' / ', ' — ' -}}
          </p>
        {%- endunless -%}

        <div class="product-info__rating">
          <div class="product-info__stars" aria-label="4.8 out of 5">
            {%- for i in (1..5) -%}
              <span class="product-info__star" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
            {%- endfor -%}
          </div>
          <a href="#product-reviews" class="product-info__review-count">
            4.8/5 &mdash; {{ section.settings.review_count | default: '12,618' }} Reviews
          </a>
        </div>

        <div class="product-info__price-row" id="product-price-row">
          <span class="product-info__price" id="product-price">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-info__compare" id="product-compare" style="font-size:var(--fs-base);text-decoration:line-through;color:var(--clr-gray-dusty);font-weight:400;">{{ product.compare_at_price | money }}</span>
            {%- assign pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round -%}
            <span class="product-info__pct-pill" id="product-pct-pill">{{ pct }}% OFF</span>
          {%- endif -%}
        </div>

        {%- assign variants_json_attr = product.variants | json -%}
        {%- form 'product', product, id: 'product-form', data-variants: variants_json_attr -%}

          {%- unless product.has_only_default_variant -%}
            {%- comment -%} Option tab bar — show only Colour, Size, Storage {%- endcomment -%}
            {%- assign allowed_opts = 'colour,color,size,storage,headboard' | split: ',' -%}
            <div class="variant-options-bar" id="variant-options-bar">
              {%- assign tab_first = true -%}
              {%- for option in product.options_with_values -%}
                {%- assign opt_handle = option.name | handleize -%}
                {%- unless allowed_opts contains opt_handle -%}{%- continue -%}{%- endunless -%}
                <button
                  type="button"
                  class="variant-option-tab {% if tab_first %}active{% endif %}"
                  data-option-panel="{{ opt_handle }}"
                  aria-label="Select {{ option.name }}">
                  <div class="variant-option-tab__icon">
                    {%- case opt_handle -%}
                      {%- when 'colour', 'color' -%}
                        <svg width="26" height="26" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="4.5" fill="currentColor" opacity=".6"/><circle cx="4" cy="11" r="3" stroke="currentColor" stroke-width="1.3"/><circle cx="18" cy="11" r="3" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="4" r="3" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="18" r="3" stroke="currentColor" stroke-width="1.3"/></svg>
                      {%- when 'size' -%}
                        <svg width="26" height="26" viewBox="0 0 22 22" fill="none"><rect x="2" y="7" width="18" height="8" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M6 7V5M11 7V4M16 7V5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                      {%- when 'storage' -%}
                        <svg width="26" height="26" viewBox="0 0 22 22" fill="none"><rect x="2" y="6" width="18" height="10" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M2 11h18" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="14" r="1" fill="currentColor"/></svg>
                      {%- when 'headboard' -%}
                        <svg width="26" height="26" viewBox="0 0 22 22" fill="none"><rect x="3" y="3" width="16" height="11" rx="3" stroke="currentColor" stroke-width="1.3"/><path d="M3 19h16M7 19v-4M15 19v-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    {%- endcase -%}
                  </div>
                  <p class="variant-option-tab__name">{{ option.name }}</p>
                  <p class="variant-option-tab__value" id="opt-tab-{{ forloop.index }}">{{ option.selected_value }}</p>
                </button>
                {%- assign tab_first = false -%}
              {%- endfor -%}
              {%- comment -%} Headboard tab — always shown, stored as line item property {%- endcomment -%}
              <button
                type="button"
                class="variant-option-tab"
                data-option-panel="headboard"
                aria-label="Select Headboard">
                <div class="variant-option-tab__icon">
                  <svg width="26" height="26" viewBox="0 0 22 22" fill="none"><rect x="3" y="3" width="16" height="11" rx="3" stroke="currentColor" stroke-width="1.3"/><path d="M3 19h16M7 19v-4M15 19v-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                </div>
                <p class="variant-option-tab__name">Headboard</p>
                <p class="variant-option-tab__value" id="opt-tab-headboard">No Headboard</p>
              </button>
            </div>

            {%- comment -%} Variant panels — one per allowed option {%- endcomment -%}
            {%- assign size_bed_icons = 'M26 2h28a2.5 2.5 0 0 1 2.5 2.5V12H23.5V4.5A2.5 2.5 0 0 1 26 2zM22 12h36v28a2 2 0 0 1-2 2H24a2 2 0 0 1-2-2V12zM29 14h22v8H29zM26 40v9M54 40v9,M20 2h40a2.5 2.5 0 0 1 2.5 2.5V12H17.5V4.5A2.5 2.5 0 0 1 20 2zM16 12h48v28a2 2 0 0 1-2 2H18a2 2 0 0 1-2-2V12zM23 14h34v8H23zM20 40v9M60 40v9,M14 2h52a2.5 2.5 0 0 1 2.5 2.5V12H11.5V4.5A2.5 2.5 0 0 1 14 2zM10 12h60v28a2 2 0 0 1-2 2H12a2 2 0 0 1-2-2V12zM13 14h24v8H13zM43 14h24v8H43zM14 40v9M66 40v9,M10 2h60a2.5 2.5 0 0 1 2.5 2.5V12H7.5V4.5A2.5 2.5 0 0 1 10 2zM6 12h68v28a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V12zM10 14h26v8H10zM44 14h26v8H44zM10 40v9M70 40v9,M6 2h68a2.5 2.5 0 0 1 2.5 2.5V12H3.5V4.5A2.5 2.5 0 0 1 6 2zM2 12h76v28a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V12zM6 14h30v8H6zM44 14h30v8H44zM6 40v9M74 40v9,M2 2h76a2.5 2.5 0 0 1 2.5 2.5V12H-.5V4.5A2.5 2.5 0 0 1 2 2zM2 12h78v28a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V12zM5 14h33v8H5zM42 14h33v8H42zM4 40v9M76 40v9' | split: ',' -%}
            {%- assign panel_first = true -%}
            {%- for option in product.options_with_values -%}
              {%- assign opt_handle = option.name | handleize -%}
              {%- unless allowed_opts contains opt_handle -%}{%- continue -%}{%- endunless -%}
              {%- assign is_size = false -%}
              {%- if opt_handle == 'size' -%}{%- assign is_size = true -%}{%- endif -%}
              {%- assign opt_value_count = option.values.size -%}
              {%- if is_size -%}
                {%- assign grid_cols = 3 -%}
              {%- elsif opt_value_count <= 4 -%}
                {%- assign grid_cols = opt_value_count -%}
              {%- else -%}
                {%- assign grid_cols = 5 -%}
              {%- endif -%}
              <div class="variant-panel {% unless panel_first %}hidden{% endunless %}" id="vpanel-{{ opt_handle }}" data-option-index="{{ forloop.index0 }}">
                <div class="variant-grid" style="grid-template-columns: repeat({{ grid_cols }}, 1fr);">
                  {%- for value in option.values -%}
                    {%- assign is_colour = false -%}
                    {%- if opt_handle == 'colour' or opt_handle == 'color' -%}{%- assign is_colour = true -%}{%- endif -%}
                    {%- assign variant_img = blank -%}
                    {%- if is_colour -%}
                      {%- for v in product.variants -%}
                        {%- if v.option1 == value or v.option2 == value or v.option3 == value -%}
                          {%- if v.image -%}{%- assign variant_img = v.image -%}{%- break -%}{%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                    {%- assign price_mod = 0 -%}
                    {%- assign base_price = product.price_min -%}
                    {%- for v in product.variants -%}
                      {%- if v.option1 == value or v.option2 == value or v.option3 == value -%}
                        {%- assign price_mod = v.price | minus: base_price -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    <button
                      type="button"
                      class="variant-card {% if option.selected_value == value %}active{% endif %}"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      data-value="{{ value | escape }}"
                      data-option-tab-id="opt-tab-{{ forloop.parentloop.index }}"
                      aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}">
                      <div class="variant-card__check">✓</div>
                      <div class="variant-card__img">
                        {%- if variant_img != blank -%}
                          <img src="{{ variant_img | image_url: width: 200 }}" alt="{{ value | escape }}" width="100" height="100" loading="lazy">
                        {%- elsif is_colour -%}
                          <span class="variant-card__colour-dot" style="background:{%- render 'swatch-color', name: value -%};"></span>
                        {%- elsif is_size -%}
                          <div class="variant-card__bed-icon">
                            <svg viewBox="0 0 80 52" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;color:var(--clr-secondary);">
                              <path d="{{ size_bed_icons[forloop.index0] }}" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                          </div>
                        {%- else -%}
                          <div class="variant-card__type-icon">
                            <svg width="32" height="32" viewBox="0 0 22 22" fill="none" style="color:var(--clr-secondary);">
                              <rect x="2" y="6" width="18" height="10" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M2 11h18" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="14" r="1" fill="currentColor"/>
                            </svg>
                          </div>
                        {%- endif -%}
                      </div>
                      <span class="variant-card__name">{{ value }}</span>
                      {%- if price_mod > 0 -%}
                        <span class="variant-card__price-mod">+{{ price_mod | money }}</span>
                      {%- endif -%}
                    </button>
                  {%- endfor -%}
                </div>
                {%- if is_size -%}
                  <div class="variant-panel__footer">
                    <a href="#product-dimensions" class="btn--dims">View Dimensions</a>
                  </div>
                {%- elsif opt_handle == 'storage' -%}
                  <div class="variant-panel__footer">
                    <a href="#product-dimensions" class="btn--dims">Storage Dimensions</a>
                  </div>
                {%- endif -%}
              </div>
              {%- assign panel_first = false -%}
            {%- endfor -%}

            {%- comment -%} Headboard panel — 3 hardcoded options stored as line item property {%- endcomment -%}
            <input type="hidden" name="properties[Headboard]" id="headboard-property" value="No Headboard">
            <div class="variant-panel hidden" id="vpanel-headboard">
              <div class="variant-grid" style="grid-template-columns: repeat(3, 1fr);">
                <button type="button" class="variant-card active" aria-pressed="true" data-hb-value="No Headboard">
                  <div class="variant-card__check">✓</div>
                  <div class="variant-card__img">
                    <div class="variant-card__type-icon">
                      <svg width="32" height="32" viewBox="0 0 22 22" fill="none" style="color:var(--clr-secondary);"><rect x="2" y="10" width="18" height="8" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M2 15h18" stroke="currentColor" stroke-width="1.3"/><path d="M6 10V8M16 10V8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </div>
                  </div>
                  <span class="variant-card__name">No Headboard</span>
                </button>
                <button type="button" class="variant-card" aria-pressed="false" data-hb-value='FREE 26" Headboard'>
                  <div class="variant-card__check">✓</div>
                  <div class="variant-card__img">
                    <div class="variant-card__type-icon">
                      <svg width="32" height="32" viewBox="0 0 22 22" fill="none" style="color:var(--clr-secondary);"><rect x="3" y="4" width="16" height="9" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M3 18h16M7 18v-5M15 18v-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </div>
                  </div>
                  <span class="variant-card__name">FREE 26&quot; Headboard</span>
                </button>
                <button type="button" class="variant-card" aria-pressed="false" data-hb-value='54" Floor Standing Headboard'>
                  <div class="variant-card__check">✓</div>
                  <div class="variant-card__img">
                    <div class="variant-card__type-icon">
                      <svg width="32" height="32" viewBox="0 0 22 22" fill="none" style="color:var(--clr-secondary);"><path d="M2 13V8a2 2 0 0 1 2-2h1.5c.8 0 1.5.6 1.5 1.5V10h9V7.5C16 6.6 16.7 6 17.5 6H19a2 2 0 0 1 2 2v5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M2 18h18M6 18v-5M16 18v-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </div>
                  </div>
                  <span class="variant-card__name">54&quot; Floor Standing Headboard</span>
                  <span class="variant-card__price-mod">+£15.00</span>
                </button>
              </div>
            </div>

          {%- endunless -%}

          <input type="hidden" name="id" id="product-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

          <button
            type="submit"
            name="add"
            class="btn btn--primary btn--full btn--atc"
            style="margin-bottom:16px;"
            data-add-to-cart
            {%- unless product.selected_or_first_available_variant.available -%}disabled{%- endunless -%}>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M1 1h2.5l1.7 8.6a2 2 0 0 0 2 1.4h7.3a2 2 0 0 0 2-1.6L17.5 4H4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="15.5" r="1.5" stroke="currentColor" stroke-width="1.4"/><circle cx="13.5" cy="15.5" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
            {%- if product.selected_or_first_available_variant.available -%}
              Add to Basket
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>

        {%- endform -%}

        <div class="product-post-atc">
          <div class="product-post-atc__delivery">
            <svg width="18" height="14" viewBox="0 0 18 14" fill="none"><path d="M1 2h11v9H1V2z" stroke="currentColor" stroke-width="1.3"/><path d="M12 5h3l2 3v3h-5V5z" stroke="currentColor" stroke-width="1.3"/><circle cx="4" cy="12" r="1.5" stroke="currentColor" stroke-width="1.3"/><circle cx="14" cy="12" r="1.5" stroke="currentColor" stroke-width="1.3"/></svg>
            <span><strong>Fast Free delivery:</strong> Select date at checkout.</span>
          </div>
          <div class="product-finance-row">
            <span class="product-finance-logo product-finance-logo--dividebuy">Divide<span style="color:var(--clr-secondary);">Buy</span></span>
            <span class="product-finance-info">{{ section.settings.dividebuy_text | default: 'Pay £40.62 p/m, 0% credit' }}</span>
          </div>
          <div class="product-finance-row" style="border-bottom:none;">
            <span class="product-finance-logo product-finance-logo--klarna">Klarna.</span>
            <span class="product-finance-info">{{ section.settings.klarna_text | default: 'Pay later in 30 days or £108.33 in 3 Monthly Installments' }}</span>
          </div>
          <div style="padding-top:12px;border-top:1px solid var(--clr-ash);margin-top:4px;">
            {%- render 'payment-icons', extended: true -%}
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

{%- render 'trust-badges-row' -%}

{%- comment -%} Mattress upsell drawer {%- endcomment -%}
{%- if section.settings.show_upsell and section.settings.mattress_blocks.size > 0 or section.blocks.size > 0 -%}
<div class="mattress-overlay" id="mattress-overlay"></div>
<div class="mattress-drawer" id="mattress-drawer" role="dialog" aria-label="Select Mattress and Save">
  <div class="mattress-drawer__header">
    <h3 class="mattress-drawer__title">Select Mattress and Save</h3>
    <button class="mattress-drawer__close" id="mattress-close" aria-label="Close">&times;</button>
  </div>
  <div class="mattress-drawer__firmness" id="firmness-tabs">
    {%- assign firmness_options = 'Medium Firm,Firm,Medium,Extra Firm,Soft' | split: ',' -%}
    {%- for f in firmness_options -%}
      <button class="firmness-tab {% if forloop.first %}active{% endif %}" data-firmness="{{ f | handleize }}">{{ f }}</button>
    {%- endfor -%}
  </div>
  <div class="mattress-drawer__list" id="mattress-list">
    {%- for block in section.blocks -%}
      {%- if block.type == 'mattress' -%}
        {%- assign saving = block.settings.compare_price | minus: block.settings.price -%}
        <div class="mattress-item" data-firmness="{{ block.settings.firmness | handleize }}" {{ block.shopify_attributes }}>
          <div class="mattress-item__radio"></div>
          <div class="mattress-item__img">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.name | escape }}" width="80" height="60" loading="lazy">
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="mattress-item__info">
            <p class="mattress-item__name">{{ block.settings.name }}</p>
            <p class="mattress-item__price">
              £{{ block.settings.price }}
              {%- if block.settings.compare_price > 0 -%}
                <span class="mattress-item__was">Was: £{{ block.settings.compare_price }}</span>
              {%- endif -%}
            </p>
            {%- if saving > 0 -%}
              <span class="mattress-item__save">SAVE: £{{ saving }}</span>
            {%- endif -%}
          </div>
          {%- if block.settings.url != blank -%}
            <a href="{{ block.settings.url }}" class="mattress-item__details" onclick="event.stopPropagation()">See Details</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<script>
(function(){
  var variants = {{ product.variants | json }};
  var selectedOptions = [
    {%- for option in product.options_with_values -%}
      "{{ option.selected_value | escape }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  function findVariant(){
    return variants.find(function(v){
      return v.options.every(function(opt,i){ return opt === selectedOptions[i]; });
    });
  }

  function updatePrice(variant){
    if(!variant) return;
    var price = document.getElementById('product-price');
    var compare = document.getElementById('product-compare');
    var pill = document.getElementById('product-pct-pill');
    var btn = document.querySelector('[data-add-to-cart]');
    var subtitle = document.getElementById('product-variant-subtitle');
    if(price) price.textContent = formatMoney(variant.price);
    if(compare){
      if(variant.compare_at_price > variant.price){
        compare.textContent = formatMoney(variant.compare_at_price);
        compare.style.display = '';
        if(pill){
          var pct = Math.round((variant.compare_at_price - variant.price) / variant.compare_at_price * 100);
          pill.textContent = pct + '% OFF';
          pill.style.display = '';
        }
      } else {
        compare.style.display = 'none';
        if(pill) pill.style.display = 'none';
      }
    }
    if(btn){
      btn.disabled = !variant.available;
      btn.querySelector('svg').nextSibling.textContent = variant.available ? ' Add to Basket' : ' Sold Out';
    }
    if(subtitle) subtitle.textContent = variant.title.replace(/ \/ /g, ' — ');
    document.getElementById('product-variant-id').value = variant.id;
  }

  function formatMoney(cents){
    return '£' + (cents / 100).toFixed(2).replace(/\.00$/, '');
  }

  // Option tab panel switching
  document.querySelectorAll('.variant-option-tab').forEach(function(tab){
    tab.addEventListener('click', function(){
      document.querySelectorAll('.variant-option-tab').forEach(function(t){ t.classList.remove('active'); });
      tab.classList.add('active');
      var panel = tab.getAttribute('data-option-panel');
      document.querySelectorAll('.variant-panel').forEach(function(p){ p.classList.add('hidden'); });
      var el = document.getElementById('vpanel-' + panel);
      if(el) el.classList.remove('hidden');
    });
  });

  // Filter thumbnails to show only images for selected colour, swap main image instantly
  function filterThumbs(colourVal, preferredSrc) {
    var colourLower = colourVal ? colourVal.toLowerCase() : '';
    var thumbs = document.querySelectorAll('.product-gallery__thumb');
    var hasColourThumbs = false;
    thumbs.forEach(function(t) {
      if ((t.getAttribute('data-colour') || '') === colourLower) hasColourThumbs = true;
    });
    var activated = false;
    thumbs.forEach(function(t) {
      var tc = t.getAttribute('data-colour') || '';
      t.style.display = hasColourThumbs ? (tc === colourLower ? '' : 'none') : '';
      t.classList.remove('active');
    });
    // Set main image to the variant's linked image (front-facing shot)
    var mainImg = document.getElementById('product-main-img');
    if (mainImg && preferredSrc) {
      mainImg.removeAttribute('srcset');
      mainImg.removeAttribute('sizes');
      mainImg.src = preferredSrc;
    }
    // Activate the thumbnail matching preferredSrc, else first visible
    thumbs.forEach(function(t) {
      if (!activated && t.style.display !== 'none') {
        var match = preferredSrc && t.getAttribute('data-src') === preferredSrc;
        if (match || !preferredSrc) { t.classList.add('active'); activated = true; }
      }
    });
    if (!activated) {
      thumbs.forEach(function(t) {
        if (!activated && t.style.display !== 'none') { t.classList.add('active'); activated = true; }
      });
    }
  }

  // Headboard card selection (line item property)
  document.querySelectorAll('[data-hb-value]').forEach(function(card){
    card.addEventListener('click', function(){
      var grid = card.closest('.variant-grid');
      grid.querySelectorAll('.variant-card').forEach(function(c){ c.classList.remove('active'); c.setAttribute('aria-pressed','false'); });
      card.classList.add('active');
      card.setAttribute('aria-pressed','true');
      var val = card.getAttribute('data-hb-value');
      var inp = document.getElementById('headboard-property');
      if (inp) inp.value = val;
      var tabVal = document.getElementById('opt-tab-headboard');
      if (tabVal) tabVal.textContent = val;
    });
  });

  // Variant card selection
  var productOptions = {{ product.options | json }};
  document.querySelectorAll('.variant-card').forEach(function(card){
    card.addEventListener('click', function(){
      if (card.hasAttribute('data-hb-value')) return; // headboard handled above
      var idx = parseInt(card.getAttribute('data-option-index'));
      var val = card.getAttribute('data-value');
      var grid = card.closest('.variant-grid');
      grid.querySelectorAll('.variant-card').forEach(function(c){ c.classList.remove('active'); c.setAttribute('aria-pressed','false'); });
      card.classList.add('active');
      card.setAttribute('aria-pressed','true');
      selectedOptions[idx] = val;
      // Update tab value display
      var tabId = card.getAttribute('data-option-tab-id');
      if(tabId){ var el = document.getElementById(tabId); if(el) el.textContent = val; }
      var variant = findVariant();
      if(variant) updatePrice(variant);
      // Filter gallery thumbnails on colour change
      var optName = productOptions[idx] || '';
      var isColour = optName.toLowerCase() === 'colour' || optName.toLowerCase() === 'color';
      if (isColour) {
        var preferredSrc = (variant && variant.featured_image) ? variant.featured_image.src : null;
        filterThumbs(val, preferredSrc);
      } else if (variant && variant.featured_image) {
        var mainImg = document.getElementById('product-main-img');
        if(mainImg){
          mainImg.removeAttribute('srcset');
          mainImg.removeAttribute('sizes');
          mainImg.src = variant.featured_image.src;
        }
      }
    });
  });

  // Thumbnail switcher
  document.getElementById('product-thumbs') && document.getElementById('product-thumbs').addEventListener('click', function(e){
    var thumb = e.target.closest('.product-gallery__thumb');
    if (!thumb) return;
    var src = thumb.getAttribute('data-src');
    var mainImg = document.getElementById('product-main-img');
    if(mainImg && src){
      mainImg.removeAttribute('srcset');
      mainImg.removeAttribute('sizes');
      mainImg.src = src;
    }
    document.querySelectorAll('.product-gallery__thumb').forEach(function(t){ t.classList.remove('active'); });
    thumb.classList.add('active');
  });


  // Qty buttons (if present)
  document.querySelectorAll('[data-qty-action]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var inp = btn.closest('.product-qty').querySelector('.product-qty__val');
      if(!inp) return;
      var v = parseInt(inp.value) || 1;
      inp.value = Math.max(1, v + (btn.getAttribute('data-qty-action') === 'increase' ? 1 : -1));
    });
  });

  // Mattress drawer
  var overlay = document.getElementById('mattress-overlay');
  var drawer = document.getElementById('mattress-drawer');
  var closeBtn = document.getElementById('mattress-close');
  function openMattressDrawer(){ if(overlay&&drawer){ overlay.classList.add('open'); drawer.classList.add('open'); document.body.style.overflow='hidden'; } }
  function closeMattressDrawer(){ if(overlay&&drawer){ overlay.classList.remove('open'); drawer.classList.remove('open'); document.body.style.overflow=''; } }
  if(overlay) overlay.addEventListener('click', closeMattressDrawer);
  if(closeBtn) closeBtn.addEventListener('click', closeMattressDrawer);
  document.querySelectorAll('[data-open-mattress]').forEach(function(btn){ btn.addEventListener('click', openMattressDrawer); });
  document.querySelectorAll('.mattress-item').forEach(function(item){
    item.addEventListener('click', function(){
      document.querySelectorAll('.mattress-item').forEach(function(i){i.classList.remove('selected')});
      item.classList.add('selected');
    });
  });
  document.querySelectorAll('.firmness-tab').forEach(function(tab){
    tab.addEventListener('click', function(){
      document.querySelectorAll('.firmness-tab').forEach(function(t){t.classList.remove('active')});
      tab.classList.add('active');
      var f = tab.getAttribute('data-firmness');
      document.querySelectorAll('.mattress-item').forEach(function(item){
        item.style.display = (!f || f === 'all' || item.getAttribute('data-firmness') === f) ? '' : 'none';
      });
    });
  });
})();
</script>

<script>
// ---- Headboard tab switching (panel is now hardcoded in Liquid) ----
(function(){
  var HB_ICON = '<svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="3" y="3" width="16" height="11" rx="3" stroke="currentColor" stroke-width="1.3"/><path d="M3 19h16M7 19v-4M15 19v-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';

  function tryInit() {
    // Skip if headboard already exists as a native Shopify option
    if (document.getElementById('vpanel-headboard')) return true;

    // Find Infinite Options headboard radio buttons or select
    var hbRadios = Array.from(document.querySelectorAll('input[type="radio"]')).filter(function(r){
      return r.name && r.name.toLowerCase().indexOf('headboard') !== -1;
    });
    var hbSelect = Array.from(document.querySelectorAll('select')).find(function(s){
      return s.name && s.name.toLowerCase().indexOf('headboard') !== -1;
    });

    if (!hbRadios.length && !hbSelect) return false;

    var values = [], getVal, setVal, groupEl;

    if (hbRadios.length) {
      hbRadios.forEach(function(r){ if (r.value) values.push({ value: r.value, label: r.value }); });
      groupEl = hbRadios[0].closest('.spo-option, .spf-option, .option-container, [class*="shoppad"]') ||
                hbRadios[0].parentElement.parentElement.parentElement;
      if (!hbRadios.some(function(r){ return r.checked; }) && hbRadios[0]) hbRadios[0].checked = true;
      getVal = function(){ var c = hbRadios.find(function(r){ return r.checked; }); return c ? c.value : values[0].value; };
      setVal = function(v){ hbRadios.forEach(function(r){ if(r.value===v){ r.checked=true; r.dispatchEvent(new Event('change',{bubbles:true})); } }); };
    } else {
      hbSelect.querySelectorAll('option').forEach(function(o){ if(o.value) values.push({ value: o.value, label: o.text.trim() }); });
      groupEl = hbSelect.closest('.spo-option, .spf-option, .option-container') || hbSelect.parentElement;
      getVal = function(){ return hbSelect.value; };
      setVal = function(v){ hbSelect.value = v; hbSelect.dispatchEvent(new Event('change',{bubbles:true})); };
    }

    if (!values.length) return false;

    // Hide the Infinite Options headboard field group
    if (groupEl) groupEl.style.display = 'none';

    // If native storage panel exists, also hide IO storage field to avoid duplication
    if (document.getElementById('vpanel-storage')) {
      var storIO = Array.from(document.querySelectorAll('input[type="radio"], select')).find(function(el){
        return el.name && el.name.toLowerCase().indexOf('storage') !== -1;
      });
      if (storIO) {
        var storGrp = storIO.closest('.spo-option, .spf-option, .option-container, [class*="shoppad"]') || storIO.parentElement.parentElement;
        if (storGrp) storGrp.style.display = 'none';
      }
    }

    // Hide entire IO wrapper if now empty
    var ioWrap = document.querySelector('#shoppad-infinite-options, .spo-container, .spf-container, [id*="infinite-options"]');
    if (ioWrap) {
      var visible = Array.from(ioWrap.querySelectorAll('input, select, textarea')).some(function(el){
        return el.closest('[style*="display: none"]') === null && el.closest('[style*="display:none"]') === null;
      });
      if (!visible) ioWrap.style.display = 'none';
    }

    // Build tab button
    var tabBar = document.getElementById('variant-options-bar');
    if (!tabBar) return false;
    var currentVal = getVal ? getVal() : values[0].value;

    var tab = document.createElement('button');
    tab.type = 'button';
    tab.className = 'variant-option-tab';
    tab.setAttribute('data-option-panel', 'headboard');
    tab.setAttribute('aria-label', 'Select Headboard');
    tab.innerHTML =
      '<div class="variant-option-tab__icon">' + HB_ICON + '</div>' +
      '<p class="variant-option-tab__name">Headboard</p>' +
      '<p class="variant-option-tab__value" id="opt-tab-headboard">' + (currentVal || 'Select') + '</p>';
    tabBar.appendChild(tab);

    // Build panel
    var panel = document.createElement('div');
    panel.className = 'variant-panel hidden';
    panel.id = 'vpanel-headboard';

    var cols = Math.min(values.length, 3);
    var grid = document.createElement('div');
    grid.className = 'variant-grid';
    grid.style.gridTemplateColumns = 'repeat(' + cols + ', 1fr)';

    values.forEach(function(v){
      var card = document.createElement('button');
      card.type = 'button';
      card.className = 'variant-card' + (v.value === currentVal ? ' active' : '');
      card.setAttribute('aria-pressed', v.value === currentVal ? 'true' : 'false');
      card.innerHTML =
        '<div class="variant-card__check">✓</div>' +
        '<div class="variant-card__img"><div class="variant-card__type-icon">' + HB_ICON + '</div></div>' +
        '<span class="variant-card__name">' + v.label + '</span>';
      card.addEventListener('click', function(){
        grid.querySelectorAll('.variant-card').forEach(function(c){ c.classList.remove('active'); c.setAttribute('aria-pressed','false'); });
        card.classList.add('active');
        card.setAttribute('aria-pressed','true');
        if (setVal) setVal(v.value);
        var tabVal = document.getElementById('opt-tab-headboard');
        if (tabVal) tabVal.textContent = v.label;
      });
      grid.appendChild(card);
    });

    panel.appendChild(grid);

    // Insert panel after last existing variant-panel (inside the form)
    var allPanels = document.querySelectorAll('.variant-panel');
    var last = allPanels[allPanels.length - 1];
    if (last) { last.parentNode.insertBefore(panel, last.nextSibling); }
    else { tabBar.parentNode.insertBefore(panel, tabBar.nextSibling); }

    // Tab click handler
    tab.addEventListener('click', function(){
      document.querySelectorAll('.variant-option-tab').forEach(function(t){ t.classList.remove('active'); });
      tab.classList.add('active');
      document.querySelectorAll('.variant-panel').forEach(function(p){ p.classList.add('hidden'); });
      panel.classList.remove('hidden');
    });

    return true;
  }

  // Try immediately; poll up to 5 s for async Infinite Options load
  if (!tryInit()) {
    var n = 0, iv = setInterval(function(){ if (tryInit() || ++n > 25) clearInterval(iv); }, 200);
  }
})();
</script>

{% schema %}
{
  "name": "Product Main",
  "blocks": [
    {
      "type": "mattress",
      "name": "Mattress Option",
      "settings": [
        { "type": "text", "id": "name", "label": "Mattress name", "default": "Klawford Cool Gel Memory 1000 Mattress" },
        { "type": "image_picker", "id": "image", "label": "Mattress image" },
        { "type": "text", "id": "price", "label": "Price (numbers only)", "default": "359.99" },
        { "type": "text", "id": "compare_price", "label": "Was price (numbers only)", "default": "719.98" },
        { "type": "select", "id": "firmness", "label": "Firmness", "options": [
          { "value": "medium-firm", "label": "Medium Firm" },
          { "value": "firm", "label": "Firm" },
          { "value": "medium", "label": "Medium" },
          { "value": "extra-firm", "label": "Extra Firm" },
          { "value": "soft", "label": "Soft" }
        ], "default": "medium-firm" },
        { "type": "url", "id": "url", "label": "See Details URL" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "review_count", "label": "Review count (display only)", "default": "12,618" },
    { "type": "header", "content": "Upsell cards" },
    { "type": "checkbox", "id": "show_upsell", "label": "Show upsell cards", "default": true },
    { "type": "text", "id": "upsell_1_label", "label": "Mattress upsell heading", "default": "Add Mattress & Save" },
    { "type": "url", "id": "upsell_1_url", "label": "Mattress upsell URL" },
    { "type": "text", "id": "upsell_2_label", "label": "Mattress button label", "default": "Choose Mattress" },
    { "type": "checkbox", "id": "show_assembly", "label": "Show assembly upsell card", "default": true },
    { "type": "text", "id": "assembly_label", "label": "Assembly title", "default": "Professional Assembly" },
    { "type": "text", "id": "assembly_desc", "label": "Assembly description", "default": "Our team will deliver your bed and mattress to your room and professionally assemble it for you." },
    { "type": "text", "id": "assembly_price", "label": "Assembly price", "default": "£39.99" },
    { "type": "header", "content": "Finance info" },
    { "type": "text", "id": "dividebuy_text", "label": "DivideBuy line", "default": "Pay £40.62 p/m, 0% credit" },
    { "type": "text", "id": "klarna_text", "label": "Klarna line", "default": "Pay later in 30 days or £108.33 in 3 Monthly Installments" }
  ]
}
{% endschema %}
