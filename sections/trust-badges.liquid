<section class="trust-badges">
  <div class="container">
    <div class="trust-badges__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge' -%}
          <div class="trust-badge" {{ block.shopify_attributes }}>
            <div class="trust-badge__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'warranty' -%}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path d="M11 2l2.4 3.2L17 4.5l.5 4L21 11l-3.5 2.5.5 4-3.6-.7L11 20l-2.4-3.2L5 17.5l-.5-4L1 11l3.5-2.5L4 4.5l3.6.7L11 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <path d="M7.5 11l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- when 'trial' -%}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <circle cx="11" cy="11" r="9" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M11 6v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                {%- when 'finance' -%}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <rect x="2" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M2 9h18" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M6 14h2M10 14h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                {%- when 'delivery' -%}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path d="M1 3h13v11H1V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <path d="M14 7h4l3 4v3h-7V7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <circle cx="5" cy="17" r="2" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="17" cy="17" r="2" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                {%- when 'handmade' -%}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path d="M11 3v4M7.5 4.5l2 3.5M14.5 4.5l-2 3.5M5 8.5c0 3 2.5 6 6 7 3.5-1 6-4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M4 14c0 3.5 3 6 7 6s7-2.5 7-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                {%- else -%}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path d="M4 11l5 5 9-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
              {%- endcase -%}
            </div>
            <span class="trust-badge__text">{{ block.settings.text }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "warranty",  "label": "Warranty / Award" },
            { "value": "trial",     "label": "Clock / Trial" },
            { "value": "finance",   "label": "Card / Finance" },
            { "value": "delivery",  "label": "Delivery truck" },
            { "value": "handmade",  "label": "Handmade / UK" },
            { "value": "check",     "label": "Check mark" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "Free Delivery"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "warranty",  "text": "5 Years Warranty" } },
        { "type": "badge", "settings": { "icon": "trial",     "text": "60 Night Risk-Free Trial" } },
        { "type": "badge", "settings": { "icon": "finance",   "text": "0% Interest Rate" } },
        { "type": "badge", "settings": { "icon": "delivery",  "text": "Fast Free Delivery" } },
        { "type": "badge", "settings": { "icon": "handmade",  "text": "Handmade in the UK" } }
      ]
    }
  ]
}
{% endschema %}
