<section class="product-real-life">
  <div class="container">
    <h2 class="section-title" style="margin-bottom:6px;">{{ section.settings.heading | default: 'In Real Life' }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="product-real-life__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Lifestyle images per product {%- endcomment -%}
  {%- assign _cdn = 'https://cdn.shopify.com/s/files/1/0960/5588/6153/files/' -%}
  {%- if product.handle == 'panel-lines-divan-bed-with-mattress-and-optional-storage-drawers' -%}
    {%- assign _imgs = 'image_2.jpg|image_6.jpg|image_4.jpg|image_1.jpg|image_3.jpg|image_5.jpg' | split: '|' -%}
    {%- assign _alts = 'Storage drawers lifestyle|Couple relaxing in bed|Family reading in bed|Luxury bedroom|Ottoman storage interior|Professional assembly' | split: '|' -%}
  {%- elsif product.handle == 'alexander-wing-back-luxury-bed-and-mattress-set' -%}
    {%- assign _imgs = 'image_1.jpg|image_6.jpg|image_4.jpg|image_2.jpg|image_3.jpg|image_5.jpg' | split: '|' -%}
    {%- assign _alts = 'Luxury grey wingback bedroom|Couple relaxing in bed|Family reading in bed|Storage drawers lifestyle|Ottoman storage interior|Professional assembly' | split: '|' -%}
  {%- else -%}
    {%- assign _imgs = '' | split: ',' -%}
    {%- assign _alts = '' | split: ',' -%}
  {%- endif -%}

  <div class="container" style="padding-right:0;overflow:hidden;">
    <div class="loved-gallery__track" id="product-gallery-track">
      {%- for block in section.blocks -%}
        {%- assign _i = forloop.index0 -%}
        <div class="gallery-item" {{ block.shopify_attributes }}>
          <div class="gallery-item__img">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.alt | escape | default: 'Klawford bed lifestyle' }}"
                loading="lazy"
                width="800"
                height="533"
                style="width:100%;height:100%;object-fit:cover;display:block;">
            {%- elsif _imgs[_i] != blank -%}
              <img
                src="{{ _cdn }}{{ _imgs[_i] }}"
                alt="{{ _alts[_i] | default: 'Klawford bed lifestyle' }}"
                loading="lazy"
                width="800"
                height="533"
                style="width:100%;height:100%;object-fit:cover;display:block;">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.show_play -%}
            <div class="gallery-item__play">
              <div class="gallery-play-btn">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M5 3l11 6-11 6V3z" fill="var(--clr-secondary)"/></svg>
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="container">
    <div class="loved-gallery__controls">
      <button class="gallery-nav-btn" onclick="document.getElementById('product-gallery-track').scrollBy({left:-240,behavior:'smooth'})" aria-label="Previous">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <button class="gallery-nav-btn" onclick="document.getElementById('product-gallery-track').scrollBy({left:240,behavior:'smooth'})" aria-label="Next">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "In Real Life Gallery",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "In Real Life" },
    { "type": "text", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_src", "label": "Image URL (fallback)" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "checkbox", "id": "show_play", "label": "Show play button", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "In Real Life Gallery", "blocks": [
    { "type": "image", "settings": { "show_play": true } },
    { "type": "image", "settings": { "show_play": true } },
    { "type": "image", "settings": { "show_play": false } },
    { "type": "image", "settings": { "show_play": true } },
    { "type": "image", "settings": { "show_play": false } },
    { "type": "image", "settings": { "show_play": false } }
  ] }]
}
{% endschema %}
