<section class="popular-categories section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="categories-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}

          {%- comment -%} Pick a fallback image based on the category label {%- endcomment -%}
          {%- case block.settings.label -%}
            {%- when 'Beds' -%}
              {%- assign fallback_img = 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=800&q=85' -%}
            {%- when 'Mattresses' -%}
              {%- assign fallback_img = 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?auto=format&fit=crop&w=800&q=85' -%}
            {%- when 'Sofas' -%}
              {%- assign fallback_img = 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=800&q=85' -%}
            {%- when 'Headboards' -%}
              {%- assign fallback_img = 'https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=800&q=85' -%}
            {%- else -%}
              {%- assign loop_imgs = 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=800&q=85,https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=800&q=85,https://images.unsplash.com/photo-1631049307264-da0ec9d70304?auto=format&fit=crop&w=800&q=85,https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=800&q=85' | split: ',' -%}
              {%- assign fallback_img = loop_imgs[forloop.index0] -%}
          {%- endcase -%}

          <a href="{{ block.settings.url | default: '/collections/all' }}" class="category-card" {{ block.shopify_attributes }}>
            <div class="category-card__img">

              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 768px) 50vw, 25vw"
                  alt="{{ block.settings.label | escape }}"
                  loading="lazy"
                  width="400"
                  height="533">
              {%- else -%}
                <div class="category-card__bg-img" style="background-image: url('{{ fallback_img }}');"></div>
              {%- endif -%}

              <div class="category-card__overlay" aria-hidden="true"></div>
              <div class="category-card__label">
                <span class="category-card__name">{{ block.settings.label }}</span>
                <span class="category-card__cta-text">
                  Shop Now
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6h7M6.5 2.5L10 6l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>

            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Popular Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Popular Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image (upload your own)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category name",
          "info": "Use exactly: Beds, Mattresses, Sofas, or Headboards to auto-load matching image",
          "default": "Beds"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popular Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "Beds",        "url": "/collections/beds" } },
        { "type": "category", "settings": { "label": "Mattresses",  "url": "/collections/mattresses" } },
        { "type": "category", "settings": { "label": "Sofas",       "url": "/collections/sofas" } },
        { "type": "category", "settings": { "label": "Headboards",  "url": "/collections/headboards" } }
      ]
    }
  ]
}
{% endschema %}
