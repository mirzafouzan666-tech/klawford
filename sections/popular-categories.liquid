<section class="popular-categories section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="categories-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a href="{{ block.settings.url | default: '/collections/all' }}" class="category-card" {{ block.shopify_attributes }}>
            <div class="category-card__img">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 768px) 50vw, 25vw"
                  alt="{{ block.settings.label | escape }}"
                  loading="lazy"
                  width="400"
                  height="533">
              {%- elsif block.settings.ext_image != blank -%}
                <img
                  src="{{ block.settings.ext_image }}"
                  alt="{{ block.settings.label | escape }}"
                  loading="lazy"
                  width="600"
                  height="800"
                  style="width:100%;height:100%;object-fit:cover;">
              {%- else -%}
                <div class="category-card__placeholder"></div>
              {%- endif -%}
              <div class="category-card__overlay" aria-hidden="true"></div>
              <div class="category-card__label">
                <span class="category-card__name">{{ block.settings.label }}</span>
                <span class="category-card__cta-text">
                  Shop Now
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6h7M6.5 2.5L10 6l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Popular Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Popular Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image (upload here)"
        },
        {
          "type": "text",
          "id": "ext_image",
          "label": "Fallback image URL (external)",
          "info": "Used when no image is uploaded above. Paste any HTTPS image URL."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category name",
          "default": "Divan Beds"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popular Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "Divan Beds",       "url": "/collections/divan-beds" } },
        { "type": "category", "settings": { "label": "Ottoman Beds",     "url": "/collections/ottoman-beds" } },
        { "type": "category", "settings": { "label": "Upholstered Beds", "url": "/collections/upholstered-beds" } },
        { "type": "category", "settings": { "label": "Mattresses",       "url": "/collections/mattresses" } }
      ]
    }
  ]
}
{% endschema %}
