<section class="popular-categories section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="categories-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a href="{{ block.settings.url }}" class="category-card" {{ block.shopify_attributes }}>
            <div class="category-card__img">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 768px) 50vw, 25vw"
                  alt="{{ block.settings.label | escape }}"
                  loading="lazy"
                  width="400"
                  height="400">
              {%- else -%}
                <div class="category-card__placeholder">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
              <div class="category-card__overlay" aria-hidden="true"></div>
              <span class="category-card__cta">Shop {{ block.settings.label }}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6h7M6.5 2.5L10 6l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Popular Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Popular Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category name",
          "default": "Divan Beds"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popular Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "Divan Beds" } },
        { "type": "category", "settings": { "label": "Ottoman Beds" } },
        { "type": "category", "settings": { "label": "Upholstered Beds" } },
        { "type": "category", "settings": { "label": "Mattresses" } }
      ]
    }
  ]
}
{% endschema %}
