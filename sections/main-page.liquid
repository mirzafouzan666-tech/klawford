{%- elsif ph == 'faq' -%}

<!-- ===== FAQ PAGE ===== -->
<div class="info-page">

  <!-- Hero -->
  <div class="info-page__hero" style="background-image:url('https://cdn.shopify.com/s/files/1/0960/5588/6153/files/alexander-cream-2.jpg');">
    <div class="info-page__hero-overlay"></div>
    <div class="container info-page__hero-inner">
      <p class="info-page__eyebrow">Got Questions?</p>
      <h1 class="info-page__hero-title">Frequently Asked Questions</h1>
      <p class="info-page__hero-sub">Everything you need to know about Klawford beds, mattresses, delivery, and more.</p>
    </div>
  </div>

  <div class="container info-page__body">

    <!-- FAQ categories -->
    <div class="faq-nav">
      <button class="faq-nav__btn active" data-cat="delivery">Delivery</button>
      <button class="faq-nav__btn" data-cat="returns">Returns &amp; Trial</button>
      <button class="faq-nav__btn" data-cat="products">Products &amp; Quality</button>
      <button class="faq-nav__btn" data-cat="payment">Finance &amp; Payment</button>
      <button class="faq-nav__btn" data-cat="warranty">Warranty</button>
    </div>

    <div class="faq-list" id="faq-list">

      <!-- DELIVERY -->
      <div class="faq-group" data-cat="delivery">
        <h2 class="faq-group__title">Delivery</h2>

        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How long does delivery take?</button>
          <div class="faq-a"><p>All Klawford orders to UK mainland are delivered within <strong>7–14 working days</strong> from your order date. You'll receive email confirmation when your order is dispatched, along with a tracking link. For Scottish Highlands and Islands, please allow 10–16 working days.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Is delivery really free?</button>
          <div class="faq-a"><p>Yes — standard delivery to UK mainland addresses is completely free on all Klawford orders, with no minimum spend. For some remote areas (Scottish Highlands, Northern Ireland, Channel Islands), a surcharge may apply — please contact us for a quote.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Do you offer weekend or evening deliveries?</button>
          <div class="faq-a"><p>Weekend and evening delivery slots are available in select postcodes. Please contact our team at <strong>sales@clickclickstore.co.uk</strong> before placing your order and we'll do our best to accommodate your requirements.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What happens if I'm not home when my delivery arrives?</button>
          <div class="faq-a"><p>Our courier will leave a card with instructions to rearrange your delivery. You can also contact us or the carrier directly to reschedule. We recommend providing a phone number so our team can give you advance notice.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Do you deliver to Northern Ireland or Ireland?</button>
          <div class="faq-a"><p>Yes, we can deliver to Northern Ireland and the Republic of Ireland. Delivery charges and timescales vary — please contact us at <strong>sales@clickclickstore.co.uk</strong> for a personalised quote before placing your order.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What is White Glove delivery?</button>
          <div class="faq-a"><p>Our White Glove delivery service means a specialist two-person team delivers your order directly to your chosen room, carries out full assembly of your bed frame, and removes all packaging from your home. Old bed and mattress removal is also available for an additional charge. This service can be selected at checkout.</p></div>
        </div>
      </div>

      <!-- RETURNS -->
      <div class="faq-group" data-cat="returns" style="display:none;">
        <h2 class="faq-group__title">Returns &amp; Trial</h2>

        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What is your returns policy?</button>
          <div class="faq-a"><p>All Klawford mattresses come with a <strong>60-night sleep trial</strong>. If you're not completely satisfied within 60 nights of delivery, contact us and we'll arrange a free collection and full refund. Beds and frames can be returned within 14 days of delivery if unused and in original packaging.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How do I start a return?</button>
          <div class="faq-a"><p>Simply email <strong>sales@clickclickstore.co.uk</strong> with your order number and reason for return. Our team will confirm eligibility and arrange a convenient collection date at no cost to you.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Why do I need to sleep on the mattress for 14 nights before returning?</button>
          <div class="faq-a"><p>Our bodies naturally take time to adjust to a new sleep surface. We ask that you sleep on your mattress for at least 14 nights to give yourself the best chance of experiencing the full benefits. After that, if you're still not happy, we're here to help.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How long does a refund take?</button>
          <div class="faq-a"><p>Once we've collected your mattress, we process refunds within <strong>5–7 working days</strong>. Refunds are returned to your original payment method. Card payments typically take 3–5 working days to appear; digital wallets are usually faster.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Do I need to keep the original packaging to return?</button>
          <div class="faq-a"><p>No — original packaging is not required for mattress returns under the 60-night trial. Our collection team will handle the mattress directly. For beds and frame returns, original packaging is required.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Do I need a mattress protector?</button>
          <div class="faq-a"><p>Yes — to be eligible for our 60-night trial, a mattress protector must be used throughout. This is a hygiene requirement that allows us to donate or recycle returned mattresses responsibly. Mattress protectors are available to purchase on our site.</p></div>
        </div>
      </div>

      <!-- PRODUCTS -->
      <div class="faq-group" data-cat="products" style="display:none;">
        <h2 class="faq-group__title">Products &amp; Quality</h2>

        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What bed sizes do you offer?</button>
          <div class="faq-a"><p>Klawford beds are available in all standard UK sizes: <strong>Small Single (2'6), Single (3'), Small Double (4'), Double (4'6), King (5'), and Super King (6')</strong>. Size availability varies by product — check each product page for options.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Are Klawford beds handmade?</button>
          <div class="faq-a"><p>Yes. Every Klawford bed is <strong>handcrafted in the UK</strong> by skilled artisans using premium materials. We take pride in British craftsmanship — each piece is built to order and made to last.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What types of beds do you sell?</button>
          <div class="faq-a"><p>Our collection includes divan beds, ottoman storage beds, panel beds, wing-back beds, and luxury upholstered frames. We also carry a range of pocket sprung and memory foam mattresses designed to complement our bed frames perfectly.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Can I choose my own fabric or colour?</button>
          <div class="faq-a"><p>Many of our beds are available in multiple fabric options and colours, selectable at the product page. For bespoke fabric requests or custom colours not listed, please contact our team and we'll advise on possibilities.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How do I care for my mattress?</button>
          <div class="faq-a"><p>To extend the life of your mattress: <strong>rotate it 180° every 3 months</strong>, always use a mattress protector, avoid jumping on it, and keep it well ventilated. Do not fold or bend your mattress. Spot clean with a mild detergent and allow to dry naturally.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What firmness mattresses do you offer?</button>
          <div class="faq-a"><p>Our mattresses are available in <strong>Soft, Medium, Medium Firm, Firm, and Extra Firm</strong> options. If you're unsure which is right for you, our general guide is: side sleepers often prefer softer options, back sleepers medium to firm, and stomach sleepers firm to extra firm.</p></div>
        </div>
      </div>

      <!-- PAYMENT -->
      <div class="faq-group" data-cat="payment" style="display:none;">
        <h2 class="faq-group__title">Finance &amp; Payment</h2>

        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Do you offer finance or pay monthly?</button>
          <div class="faq-a"><p>Yes — Klawford offers flexible finance options to help spread the cost of your purchase. Finance is available at checkout through our trusted payment partners. Representative APR and eligibility details are displayed at the point of application.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What payment methods do you accept?</button>
          <div class="faq-a"><p>We accept all major credit and debit cards (Visa, Mastercard, American Express), PayPal, Apple Pay, Google Pay, and finance options through our checkout. All payments are processed securely.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Is your website payment secure?</button>
          <div class="faq-a"><p>Absolutely. Our site uses <strong>SSL encryption</strong> and all payment data is processed through PCI-DSS compliant systems. We never store your card details. Look for the padlock icon in your browser's address bar when checking out.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Can I change or cancel my order?</button>
          <div class="faq-a"><p>Orders can be amended or cancelled within <strong>24 hours</strong> of placing. Because our beds are made to order, we're unable to cancel after production has begun. Please contact us immediately at <strong>sales@clickclickstore.co.uk</strong> if you need to make changes.</p></div>
        </div>
      </div>

      <!-- WARRANTY -->
      <div class="faq-group" data-cat="warranty" style="display:none;">
        <h2 class="faq-group__title">Warranty</h2>

        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What warranty do Klawford products come with?</button>
          <div class="faq-a"><p>All Klawford beds and mattresses come with a <strong>manufacturer's guarantee</strong> covering structural faults and manufacturing defects. Warranty periods vary by product — details are listed on each product page.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What does the warranty cover?</button>
          <div class="faq-a"><p>The warranty covers manufacturing defects including structural failures, faulty joints, and material defects that arise under normal domestic use. It does not cover wear and tear, damage from misuse, or damage caused by improper assembly.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How do I make a warranty claim?</button>
          <div class="faq-a"><p>Contact our team at <strong>sales@clickclickstore.co.uk</strong> with your order number, a description of the issue, and clear photographs of the fault. Our team will assess and respond within 2 working days with next steps.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">My item arrived damaged — what should I do?</button>
          <div class="faq-a"><p>If your item arrives damaged, please <strong>note it on the delivery paperwork</strong> before signing, take photographs, and contact us within <strong>48 hours</strong> of delivery. We'll arrange a replacement or repair as quickly as possible at no cost to you.</p></div>
        </div>
      </div>

    </div><!-- /faq-list -->

    <!-- Still have questions -->
    <div class="info-cta">
      <h2 class="info-cta__title">Still Have a Question?</h2>
      <p class="info-cta__text">Our team is available Monday–Friday and would love to help you find the perfect Klawford bed or mattress.</p>
      <a href="mailto:sales@clickclickstore.co.uk" class="btn btn--primary">Email Our Team</a>
    </div>

  </div>
</div>

<script>
(function(){
  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = this.closest('.faq-item');
      var open = item.classList.contains('is-open');
      item.closest('.faq-group').querySelectorAll('.faq-item').forEach(function(i){ i.classList.remove('is-open'); i.querySelector('.faq-q').setAttribute('aria-expanded','false'); });
      if(!open){ item.classList.add('is-open'); this.setAttribute('aria-expanded','true'); }
    });
  });
  // Category filter
  document.querySelectorAll('.faq-nav__btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var cat = this.getAttribute('data-cat');
      document.querySelectorAll('.faq-nav__btn').forEach(function(b){ b.classList.remove('active'); });
      this.classList.add('active');
      document.querySelectorAll('.faq-group').forEach(function(g){
        g.style.display = g.getAttribute('data-cat') === cat ? '' : 'none';
      });
    });
  });
})();
</script>

{%- else -%}

