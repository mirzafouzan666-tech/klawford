.info-cta{background:var(--clr-secondary);border-radius:var(--radius-base);padding:3rem 2rem;text-align:center;color:#fff;}
.info-cta__title{font-family:var(--ff-primary);font-size:clamp(1.4rem,3vw,2rem);margin-bottom:.75rem;color:#fff;}
.info-cta__text{margin-bottom:1.5rem;opacity:.9;max-width:500px;margin-inline:auto;line-height:1.6;}
.info-cta .btn--primary{background:#fff;color:var(--clr-secondary);border-color:#fff;}
.info-cta .btn--primary:hover{background:var(--clr-primary);border-color:var(--clr-primary);}
.faq-nav{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2.5rem;border-bottom:2px solid rgba(92,31,46,.12);padding-bottom:1rem;}
.faq-nav__btn{background:none;border:1.5px solid rgba(92,31,46,.25);color:var(--clr-secondary);font-size:var(--fs-sm);padding:.55rem 1.1rem;border-radius:var(--radius-full);cursor:pointer;transition:background .2s,color .2s;}
.faq-nav__btn.active,.faq-nav__btn:hover{background:var(--clr-secondary);border-color:var(--clr-secondary);color:#fff;}
.faq-group__title{font-family:var(--ff-primary);font-size:clamp(1.3rem,2.5vw,1.75rem);color:var(--clr-secondary);margin-bottom:1.25rem;}
.faq-item{border-bottom:1px solid rgba(92,31,46,.12);}
.faq-q{width:100%;background:none;border:none;text-align:left;padding:1.1rem 0;font-size:var(--fs-base);font-family:var(--ff-primary);color:var(--clr-text);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:1rem;}
.faq-q::after{content:'+';font-size:1.4rem;color:var(--clr-secondary);flex-shrink:0;line-height:1;}
.faq-item.is-open .faq-q::after{content:'−';}
.faq-a{display:none;padding:0 0 1.25rem;}
.faq-a p{font-size:var(--fs-sm);line-height:1.75;color:var(--clr-text-light);margin:0;}
.faq-item.is-open .faq-a{display:block;}
.privacy-meta{font-size:var(--fs-sm);color:var(--clr-text-light);margin-top:-2rem;margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid rgba(92,31,46,.12);}
.privacy-section{display:flex;flex-direction:column;gap:1rem;}
.privacy-section h2{font-family:var(--ff-primary);font-size:clamp(1.2rem,2.5vw,1.6rem);color:var(--clr-secondary);padding-bottom:.5rem;border-bottom:2px solid rgba(92,31,46,.12);}
.privacy-section p,.privacy-section a{font-size:var(--fs-sm);line-height:1.75;color:var(--clr-text-light);}
.privacy-section a{color:var(--clr-secondary);text-decoration:underline;}
.not-found{text-align:center;padding:6rem 0;}
.not-found h1{font-size:8rem;font-family:var(--ff-primary);color:var(--clr-secondary);opacity:.15;line-height:1;margin-bottom:1rem;}
.not-found h2{font-family:var(--ff-primary);font-size:2rem;color:var(--clr-secondary);margin-bottom:.75rem;}
.not-found p{color:var(--clr-text-light);margin-bottom:2rem;}
</style>

