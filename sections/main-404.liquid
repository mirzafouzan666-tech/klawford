<script>
(function(){
  var path = window.location.pathname.replace(/\/$/, '');
  var map = {
    '/pages/delivery':              'pg-delivery',
    '/pages/delivery-information':  'pg-delivery',
    '/pages/shipping-information':  'pg-delivery',
    '/pages/shipping':              'pg-delivery',
    '/pages/returns':               'pg-returns',
    '/pages/returns-policy':        'pg-returns',
    '/pages/return-policy':         'pg-returns',
    '/pages/refunds':               'pg-returns',
    '/pages/faq':                   'pg-faq',
    '/pages/faqs':                  'pg-faq',
    '/pages/frequently-asked-questions': 'pg-faq',
    '/pages/privacy-policy':        'pg-privacy',
    '/pages/privacy':               'pg-privacy'
  };
  var id = map[path] || 'pg-404';
  var el = document.getElementById(id);
  if(el) el.style.display = '';

  /* Update page title and meta description */
  var meta = {
    'pg-delivery': {
      t: 'Free Bed & Mattress Delivery UK | Klawford',
      d: 'Free UK mainland delivery on all Klawford beds and mattresses. 7-14 working days, white glove assembly service available. Order online today.'
    },
    'pg-returns': {
      t: '60-Night Mattress Trial & Returns Policy | Klawford UK',
      d: 'Shop risk-free with Klawford\'s 60-night mattress sleep trial. Free collection, full refund guaranteed. Buy luxury beds & mattresses with total confidence.'
    },
    'pg-faq': {
      t: 'FAQs | Beds, Mattresses & Delivery | Klawford UK',
      d: 'Answers to common questions about buying beds and mattresses online in the UK — delivery, returns, sizes, firmness, finance and more. Klawford FAQ.'
    },
    'pg-privacy': {
      t: 'Privacy Policy | Klawford UK',
      d: 'Klawford\'s Privacy Policy — how we collect, use, and protect your personal data in accordance with UK GDPR and the Data Protection Act 2018.'
    }
  };
  if(meta[id]){
    document.title = meta[id].t;
    var dm = document.querySelector('meta[name="description"]');
    if(dm){ dm.content = meta[id].d; }
    else { var m=document.createElement('meta'); m.name='description'; m.content=meta[id].d; document.head.appendChild(m); }
  }

  /* FAQ accordion */
  document.querySelectorAll('.faq-q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=this.closest('.faq-item'), open=item.classList.contains('is-open');
      item.closest('.faq-group').querySelectorAll('.faq-item').forEach(function(i){i.classList.remove('is-open');i.querySelector('.faq-q').setAttribute('aria-expanded','false');});
      if(!open){item.classList.add('is-open');this.setAttribute('aria-expanded','true');}
    });
  });
  /* FAQ category tabs */
  document.querySelectorAll('.faq-nav__btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var cat=this.getAttribute('data-cat');
      document.querySelectorAll('.faq-nav__btn').forEach(function(b){b.classList.remove('active');});
      this.classList.add('active');
      document.querySelectorAll('.faq-group').forEach(function(g){g.style.display=g.getAttribute('data-cat')===cat?'':'none';});
    });
  });
})();
</script>

