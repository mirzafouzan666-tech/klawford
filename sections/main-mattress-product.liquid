{%- comment -%} ── FAQ ─────────────────────────────────────────────────────── {%- endcomment -%}
<section class="klm-faq" id="klm-faq">
  <div class="container">
    <h2 class="klm-section__heading">Frequently Asked Questions</h2>
    <div class="klm-faq__list">
      <details class="klm-faq__item">
        <summary class="klm-faq__q">Do your products conform to UK fire safety regulations?</summary>
        <div class="klm-faq__a">Yes — all Klawford mattresses meet UK fire safety regulations under The Furniture and Furnishings (Fire Safety) Regulations 1988 (amended). You can sleep safely and confidently in every mattress we sell.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">What sizes are available?</summary>
        <div class="klm-faq__a">Our mattresses are available in Single (3ft), Small Double (4ft), Double (4ft 6), King (5ft), and Super King (6ft) — all standard UK sizes. Select your size using the size grid at the top of this page.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">How long does delivery take once I have placed my order?</summary>
        <div class="klm-faq__a">We typically deliver within 3–7 working days. You will be contacted to choose a delivery date that suits you, and our 2-man team will bring the mattress straight to your room of choice.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">What is a 60-night risk-free trial, and what does this mean?</summary>
        <div class="klm-faq__a">We give you 60 nights to sleep on your new mattress before making your final decision. If it is not right for you within that period, contact our team and we will arrange a return and a full refund — no questions asked.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">Can I place my order over the phone?</summary>
        <div class="klm-faq__a">Yes — call us on 01924 926117 and one of our team will be happy to take your order, help you choose the right size and firmness, and arrange delivery at a time that works for you.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">What does the 5-year warranty cover?</summary>
        <div class="klm-faq__a">The 5-year warranty covers manufacturing defects and structural issues — including sagging, spring failure, and cover defects that arise from normal use. If anything goes wrong, contact us and we will repair or replace it at no cost to you.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">Can I pay monthly or through financing options?</summary>
        <div class="klm-faq__a">Yes — we offer 0% interest-free financing through DivideBuy, letting you spread the cost over up to 12 months with no extra charges. Klarna is also available for pay-later or 3-payment options at checkout.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">Is the cover removable and washable?</summary>
        <div class="klm-faq__a">Our mattresses come with a removable zip cover that is machine washable. This makes it easy to keep your sleep environment clean and fresh without having to move the whole mattress.</div>
      </details>
      <details class="klm-faq__item">
        <summary class="klm-faq__q">Where are your products manufactured?</summary>
        <div class="klm-faq__a">Our mattresses are built using quality UK-sourced materials to ensure consistent comfort, durability, and safety standards in every product we sell.</div>
      </details>
    </div>
  </div>
</section>

<script>
(function(){
  var variants = {{ product.variants | json }};

  /* ── Size button clicks ──────────────────────────────────────── */
  function updateSizePriceDiffs(selectedPrice) {
    document.querySelectorAll('.klm-size-btn').forEach(function(b) {
      var btnPrice = parseInt(b.dataset.price, 10);
      var priceEl  = b.querySelector('[data-role="price"]');
      if (!priceEl) return;
      if (b.classList.contains('is-active')) {
        priceEl.textContent = formatMoney(btnPrice);
        priceEl.className = 'klm-size-btn__price';
      } else {
        var diff = btnPrice - selectedPrice;
        if (diff < 0) {
          priceEl.textContent = '-' + formatMoney(Math.abs(diff));
          priceEl.className = 'klm-size-btn__price klm-size-btn__price--save';
        } else if (diff > 0) {
          priceEl.textContent = '+' + formatMoney(diff);
          priceEl.className = 'klm-size-btn__price';
        } else {
          priceEl.textContent = formatMoney(btnPrice);
          priceEl.className = 'klm-size-btn__price';
        }
      }
    });
  }

  document.querySelectorAll('.klm-size-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.klm-size-btn').forEach(function(b){
        b.classList.remove('is-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');

      var vid     = btn.dataset.vid;
      var price   = parseInt(btn.dataset.price, 10);
      var compare = parseInt(btn.dataset.compare, 10);
      var name    = btn.dataset.size;

      var nameEl = document.getElementById('klm-size-name');
      if (nameEl) nameEl.textContent = name;

      /* Update header price */
      var priceEl   = document.getElementById('klm-price');
      var compareEl = document.getElementById('klm-compare');
      var pctEl     = document.getElementById('klm-pct');
      if (priceEl) priceEl.textContent = formatMoney(price);
      if (compareEl && pctEl) {
        if (compare > price) {
          compareEl.textContent = formatMoney(compare);
          compareEl.style.display = '';
          var pct = Math.round((compare - price) / compare * 100);
          pctEl.textContent = pct + '% OFF';
          pctEl.style.display = '';
        } else {
          compareEl.style.display = 'none';
          pctEl.style.display = 'none';
        }
      }

      /* Update all size button price diffs relative to new selection */
      updateSizePriceDiffs(price);

      var inp = document.getElementById('klm-variant-id');
      if (inp) inp.value = vid;

      var atcBtns = document.querySelectorAll('.klm-atc');
      var variant = variants.find(function(v){ return String(v.id) === String(vid); });
      var avail = variant ? variant.available : true;
      atcBtns.forEach(function(b){ b.disabled = !avail; });
      var labelEl = document.getElementById('klm-atc-label');
      if (labelEl) labelEl.textContent = avail ? 'Add to Basket' : 'Sold Out';
    });
  });

  function formatMoney(cents){
    return '£' + (cents / 100).toFixed(2).replace(/\.00$/, '');
  }

  /* ── Thumbnail gallery ───────────────────────────────────────── */
  var thumbsEl = document.getElementById('klm-thumbs');
  var mainImg  = document.getElementById('klm-main-img');

  if (thumbsEl && mainImg) {
    thumbsEl.addEventListener('click', function(e){
      var thumb = e.target.closest('.klm-gallery__thumb');
      if (!thumb) return;
      mainImg.src = thumb.dataset.src;
      mainImg.removeAttribute('srcset');
      mainImg.removeAttribute('sizes');
      document.querySelectorAll('.klm-gallery__thumb').forEach(function(t){ t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  }

  var prevBtn = document.getElementById('klm-thumb-prev');
  var nextBtn = document.getElementById('klm-thumb-next');
  if (prevBtn && thumbsEl) prevBtn.addEventListener('click', function(){ thumbsEl.scrollBy({ left: -200, behavior: 'smooth' }); });
  if (nextBtn && thumbsEl) nextBtn.addEventListener('click', function(){ thumbsEl.scrollBy({ left: 200, behavior: 'smooth' }); });

  /* ── Features icon selector + indicator pip ─────────────────── */
  var featData = [
    { name: 'Air Vents', body: 'Built-in ventilation channels draw heat and moisture away from the mattress core, keeping the sleeping surface fresh and breathable throughout the night.' },
    { name: 'Hypoallergenic', body: 'All fillings and covers are hypoallergenic and dust mite resistant — the ideal choice for allergy sufferers, those with asthma, or anyone with sensitive skin.' },
    { name: 'Orthopaedic Support', body: 'Engineered to keep your spine in neutral alignment and relieve pressure on hips, shoulders, and lower back — so you wake up feeling genuinely rested, not stiff.' },
    { name: 'Washable Cover', body: 'The removable zip cover is machine washable, making it easy to keep your sleep environment clean and fresh without having to move the entire mattress.' },
    { name: 'Pressure Relief', body: 'Targeted comfort zones respond to the specific weight of your body, cushioning pressure points at the hips and shoulders so you sleep through the night without discomfort.' },
    { name: 'Temperature Regulation', body: 'Heat and moisture-wicking materials draw warmth away from the sleep surface through the night, keeping you at the ideal temperature so you stay comfortable from dusk to dawn.' },
    { name: 'Motion Isolation', body: 'Each zone of the mattress responds only to the pressure directly applied to it, so your partner\'s movement at night will not carry across to your side.' },
    { name: 'UK Quality', body: 'Every material is selected for quality, durability, and long-lasting performance — built to a standard, not a price point, so your mattress keeps delivering night after night.' }
  ];

  var titleEl = document.getElementById('klm-feat-title');
  var bodyEl  = document.getElementById('klm-feat-body');
  var pipEl   = document.getElementById('klm-feat-pip');

  function movePip(activeBtn) {
    if (!pipEl) return;
    var track = document.querySelector('.klm-features__track');
    if (!track) return;
    var trackRect = track.getBoundingClientRect();
    var btnRect   = activeBtn.getBoundingClientRect();
    var center    = btnRect.left + btnRect.width / 2 - trackRect.left;
    pipEl.style.left = center + 'px';
  }

  document.querySelectorAll('.klm-feat').forEach(function(btn, i){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.klm-feat').forEach(function(b){
        b.classList.remove('is-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-selected', 'true');
      if (titleEl && featData[i]) titleEl.textContent = featData[i].name;
      if (bodyEl  && featData[i]) bodyEl.textContent  = featData[i].body;
      movePip(btn);
    });
  });

  /* Set initial pip position */
  var firstFeat = document.querySelector('.klm-feat.is-active');
  if (firstFeat) {
    setTimeout(function(){ movePip(firstFeat); }, 50);
  }
  window.addEventListener('resize', function(){
    var activeFeat = document.querySelector('.klm-feat.is-active');
    if (activeFeat) movePip(activeFeat);
  });

  /* ── FAQ accordion: close others when one opens ──────────────── */
  document.querySelectorAll('.klm-faq__item').forEach(function(det){
    det.addEventListener('toggle', function(){
      if (det.open) {
        document.querySelectorAll('.klm-faq__item').forEach(function(d){
          if (d !== det) d.open = false;
        });
      }
    });
  });

})();
</script>

