<div class="kl-cart-page">

  {%- if cart.item_count > 0 -%}

    <div class="kl-cart-header">
      <div class="container">
        <div class="kl-cart-header__inner">
          <div>
            <h1 class="kl-cart-title">Your Basket</h1>
            <p class="kl-cart-count">{{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %} in your order</p>
          </div>
          <a href="/collections/all" class="kl-cart-continue">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Continue Shopping
          </a>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="kl-cart-layout">

        {%- comment -%} ---- LEFT: Items ---- {%- endcomment -%}
        <div class="kl-cart-items">

          {%- comment -%} Trust bar {%- endcomment -%}
          <div class="kl-cart-trust">
            <div class="kl-cart-trust__item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2 4h4l1.5 8h9L18 7H6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8" cy="16.5" r="1.5" stroke="currentColor" stroke-width="1.4"/><circle cx="15" cy="16.5" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
              <span>Free 2-Man Delivery</span>
            </div>
            <div class="kl-cart-trust__item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l1.8 5.5H18l-4.9 3.6 1.9 5.7L10 13.5l-5 3.3 1.9-5.7L2 7.5h6.2L10 2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
              <span>60-Night Risk Free Trial</span>
            </div>
            <div class="kl-cart-trust__item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 6h6l-5 3.6 1.9 5.9L10 14l-4.9 3.5L7 11.6 2 8h6L10 2z" stroke="none"/><path d="M10 3C5 3 2 7 2 10s3 7 8 7 8-3 8-7-3-7-8-7z" stroke="currentColor" stroke-width="1.4"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              <span>Handmade in the UK</span>
            </div>
            <div class="kl-cart-trust__item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="5" width="16" height="11" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M2 9h16" stroke="currentColor" stroke-width="1.4"/></svg>
              <span>0% Interest Finance</span>
            </div>
          </div>

          {%- comment -%} Column headers (desktop) {%- endcomment -%}
          <div class="kl-cart-cols-head">
            <span>Product</span>
            <span>Price</span>
            <span>Qty</span>
            <span>Total</span>
          </div>

          {%- form 'cart', cart, id: 'kl-cart-form' -%}
            {%- for item in cart.items -%}
              <div class="kl-cart-row" data-key="{{ item.key }}">

                <a href="{{ item.url }}" class="kl-cart-row__img">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="100" height="100" loading="lazy">
                  {%- endif -%}
                </a>

                <div class="kl-cart-row__info">
                  <a href="{{ item.url }}" class="kl-cart-row__name">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="kl-cart-row__variant">{{ item.variant.title | replace: ' / ', ' · ' }}</p>
                  {%- endunless -%}
                  {%- if item.variant.sku != blank -%}
                    <p class="kl-cart-row__sku">SKU: {{ item.variant.sku }}</p>
                  {%- endif -%}
                  <button
                    type="button"
                    class="kl-cart-row__remove"
                    data-cart-remove="{{ item.key }}"
                    aria-label="Remove {{ item.title | escape }}">
                    Remove
                  </button>
                </div>

                <span class="kl-cart-row__price">{{ item.price | money }}</span>

                <div class="kl-cart-row__qty">
                  <button type="button" class="kl-qty-btn" data-action="decrease" data-key="{{ item.key }}" aria-label="Decrease quantity">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                  <span class="kl-qty-val">{{ item.quantity }}</span>
                  <button type="button" class="kl-qty-btn" data-action="increase" data-key="{{ item.key }}" aria-label="Increase quantity">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 2v8M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>

                <span class="kl-cart-row__total">{{ item.line_price | money }}</span>

              </div>
            {%- endfor -%}
          {%- endform -%}

        </div>

        {%- comment -%} ---- RIGHT: Order Summary ---- {%- endcomment -%}
        <div class="kl-cart-summary">
          <div class="kl-cart-summary__card">
            <h2 class="kl-cart-summary__title">Order Summary</h2>

            <div class="kl-cart-summary__row">
              <span>Subtotal ({{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %})</span>
              <span class="kl-cart-summary__price" id="kl-cart-subtotal">{{ cart.total_price | money }}</span>
            </div>
            <div class="kl-cart-summary__row">
              <span>Delivery</span>
              <span class="kl-cart-summary__free">FREE</span>
            </div>
            <div class="kl-cart-summary__row kl-cart-summary__row--total">
              <span>Total</span>
              <span id="kl-cart-total">{{ cart.total_price | money }}</span>
            </div>

            <p class="kl-cart-summary__vat">Taxes included. Shipping calculated at checkout.</p>

            <a href="/checkout" class="btn btn--primary btn--block kl-cart-checkout-btn">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h2.5L6 11.5H13M7 13.5a1 1 0 1 0 2 0 1 1 0 0 0-2 0zM12 13.5a1 1 0 1 0 2 0 1 1 0 0 0-2 0z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Proceed to Checkout
            </a>

            <a href="/collections/all" class="kl-cart-summary__continue">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 11L5 7l4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              Continue Shopping
            </a>

            <div class="kl-cart-summary__trust">
              <div class="kl-cart-summary__trust-item">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1l1.6 5H17l-4.4 3.2 1.7 5.2L9 11.4l-5.3 3 1.7-5.2L1 6h6.4L9 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                <span>4.9/5 Trustpilot</span>
              </div>
              <div class="kl-cart-summary__trust-item">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2C5 2 2 5 2 9s3 7 7 7 7-3 7-7-3-7-7-7z" stroke="currentColor" stroke-width="1.3"/><path d="M6 9l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                <span>60-Night Trial</span>
              </div>
              <div class="kl-cart-summary__trust-item">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 4h12v8H2V4z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M2 7h12" stroke="currentColor" stroke-width="1.3"/></svg>
                <span>0% Finance</span>
              </div>
            </div>

            <div class="kl-cart-payment-icons">
              {%- render 'payment-icons' -%}
            </div>
          </div>
        </div>

      </div>{%- comment -%} /kl-cart-layout {%- endcomment -%}

      {%- comment -%} ---- Payment Options Section ---- {%- endcomment -%}
      <div class="kl-pay-methods">
        <h3 class="kl-pay-methods__title">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M1 6h14" stroke="currentColor" stroke-width="1.4"/></svg>
          Payment Options
        </h3>
        <p class="kl-pay-methods__sub">All transactions are secure and encrypted.</p>

        <div class="kl-pay-methods__list">

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">Credit / Debit Card</span>
            </div>
            <div class="kl-pay-row__icons">
              {{- 'visa'           | payment_type_svg_tag: class: 'kl-pay-ico' -}}
              {{- 'master'         | payment_type_svg_tag: class: 'kl-pay-ico' -}}
              {{- 'american_express' | payment_type_svg_tag: class: 'kl-pay-ico' -}}
            </div>
          </div>

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">Shop Pay</span>
              <span class="kl-pay-row__desc">Pay in full or in installments</span>
            </div>
            <div class="kl-pay-row__icons">
              {{- 'shopify_pay' | payment_type_svg_tag: class: 'kl-pay-ico' -}}
            </div>
          </div>

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">Snap Finance</span>
              <span class="kl-pay-row__desc">Up to 4 Years Inclusive Finance (Rep 29.9% APR)</span>
            </div>
            <div class="kl-pay-row__icons">
              <span class="kl-pay-ico kl-pay-ico--snap">
                <svg width="44" height="28" viewBox="0 0 44 28" xmlns="http://www.w3.org/2000/svg"><rect width="44" height="28" rx="4" fill="#003057"/><text x="5" y="19" font-family="Arial,sans-serif" font-size="11" font-weight="900" fill="#FFCC00">snap</text></svg>
              </span>
            </div>
          </div>

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">Clearpay</span>
              <span class="kl-pay-row__desc">Pay in 3 interest-free instalments</span>
            </div>
            <div class="kl-pay-row__icons">
              <span class="kl-pay-ico kl-pay-ico--clearpay">
                <svg width="44" height="28" viewBox="0 0 44 28" xmlns="http://www.w3.org/2000/svg"><rect width="44" height="28" rx="4" fill="#B2FCE4" stroke="#00D166" stroke-width="1"/><text x="4" y="19" font-family="Arial,sans-serif" font-size="8.5" font-weight="800" fill="#000">clear</text><text x="28" y="19" font-family="Arial,sans-serif" font-size="8.5" font-weight="800" fill="#00703C">pay</text></svg>
              </span>
            </div>
          </div>

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">DivideBuy</span>
              <span class="kl-pay-row__desc">Spread the cost with 0% interest finance</span>
            </div>
            <div class="kl-pay-row__icons">
              {{- 'visa'   | payment_type_svg_tag: class: 'kl-pay-ico' -}}
              {{- 'master' | payment_type_svg_tag: class: 'kl-pay-ico' -}}
            </div>
          </div>

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">Klarna</span>
              <span class="kl-pay-row__desc">Pay flexibly — buy now, pay later</span>
            </div>
            <div class="kl-pay-row__icons">
              {{- 'klarna' | payment_type_svg_tag: class: 'kl-pay-ico' -}}
            </div>
          </div>

          <div class="kl-pay-row">
            <div class="kl-pay-row__left">
              <span class="kl-pay-row__name">PayPal</span>
              <span class="kl-pay-row__desc">Fast & secure checkout with PayPal</span>
            </div>
            <div class="kl-pay-row__icons">
              {{- 'paypal' | payment_type_svg_tag: class: 'kl-pay-ico' -}}
            </div>
          </div>

        </div>
      </div>

    </div>

  {%- else -%}

    {%- comment -%} Empty state {%- endcomment -%}
    <div class="kl-cart-empty">
      <div class="kl-cart-empty__icon">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 6h6.5l5 24M19 30h28l-4 18H23L19 30z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="26" cy="53" r="3" stroke="currentColor" stroke-width="2"/>
          <circle cx="43" cy="53" r="3" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
      <h1 class="kl-cart-empty__title">Your Basket is Empty</h1>
      <p class="kl-cart-empty__sub">Looks like you haven't added anything yet. Let's change that.</p>
      <div class="kl-cart-empty__links">
        <a href="/collections/divan-beds" class="btn btn--primary btn--lg">Shop Divan Beds</a>
        <a href="/collections/all" class="btn btn--outline btn--lg">Browse All Beds</a>
      </div>
      <div class="kl-cart-empty__trust">
        <span>⭐ 4.9/5 Trustpilot</span>
        <span>🚚 Free 2-Man Delivery</span>
        <span>✓ 60-Night Trial</span>
        <span>🇬🇧 Handmade in the UK</span>
      </div>
    </div>

  {%- endif -%}

</div>

<script>
(function(){
  function cartFetch(url, body){
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(body)
    }).then(function(r){ return r.json(); });
  }

  function refreshCartTotals(cart){
    var sub = document.getElementById('kl-cart-subtotal');
    var tot = document.getElementById('kl-cart-total');
    if(!sub||!tot||!cart) return;
    var fmt = function(c){ return '£' + (c/100).toFixed(2).replace(/\.00$/,''); };
    sub.textContent = fmt(cart.total_price);
    tot.textContent = fmt(cart.total_price);
  }

  function removeRow(key){
    var row = document.querySelector('[data-key="'+key+'"]');
    if(row){ row.style.opacity='0'; row.style.transition='opacity .2s'; setTimeout(function(){ row.remove(); },200); }
  }

  // Remove item
  document.querySelectorAll('[data-cart-remove]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.getAttribute('data-cart-remove');
      cartFetch('/cart/change.js', { id: key, quantity: 0 }).then(function(cart){
        removeRow(key);
        refreshCartTotals(cart);
        if(cart.item_count === 0) location.reload();
      });
    });
  });

  // Qty change
  document.querySelectorAll('.kl-qty-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.getAttribute('data-key');
      var row = btn.closest('.kl-cart-row');
      var valEl = row ? row.querySelector('.kl-qty-val') : null;
      if(!valEl) return;
      var current = parseInt(valEl.textContent) || 1;
      var next = btn.getAttribute('data-action') === 'increase' ? current + 1 : Math.max(0, current - 1);
      if(next === 0){
        cartFetch('/cart/change.js', { id: key, quantity: 0 }).then(function(cart){
          removeRow(key);
          refreshCartTotals(cart);
          if(cart.item_count === 0) location.reload();
        });
      } else {
        valEl.textContent = next;
        cartFetch('/cart/change.js', { id: key, quantity: next }).then(function(cart){
          var totalEl = row ? row.querySelector('.kl-cart-row__total') : null;
          if(cart && cart.items){
            var item = cart.items.find(function(i){ return i.key === key; });
            if(item && totalEl){ totalEl.textContent = '£' + (item.line_price/100).toFixed(2).replace(/\.00$/,''); }
          }
          refreshCartTotals(cart);
        });
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
