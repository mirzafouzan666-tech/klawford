<section class="hero-banner">

  <div class="hero-banner__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 768 }} 768w,
                {{ section.settings.image | image_url: width: 1280 }} 1280w,
                {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape | default: shop.name }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080">
    {%- else -%}
      <div class="hero-banner__placeholder" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <div class="hero-banner__inner">
    <div class="container">
      <div class="hero-banner__content">

        {%- if section.settings.badge_text != blank -%}
          <div class="hero-badge">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M1.5 5l2.5 2.5 4.5-4.5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.badge_text }}
          </div>
        {%- endif -%}

        <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>

        {%- if section.settings.subheading != blank -%}
          <div class="hero-banner__promo-row">
            <span class="hero-promo-icon" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 6l3 3.5 5-5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="hero-banner__sub">{{ section.settings.subheading }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.promo_code != blank -%}
          <div class="hero-code-inline">
            <span class="hero-code-label">USE CODE</span>
            <span class="hero-code-value">{{ section.settings.promo_code }}</span>
          </div>
        {%- endif -%}

        <div class="hero-banner__buttons">
          {%- assign btn_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'button' -%}
              {%- assign btn_index = btn_index | plus: 1 -%}
              <a href="{{ block.settings.url | default: '/collections/all' }}"
                 class="btn {% if btn_index == 1 %}btn--primary btn--lg{% else %}btn--ghost-dark{% endif %}"
                 {{ block.shopify_attributes }}>
                {{ block.settings.label }}
                {%- if btn_index == 1 -%}
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.trust_text != blank -%}
          <div class="hero-mini-trust">
            <div class="hero-mini-stars" aria-label="Rated 5 stars">
              {%- for i in (1..5) -%}
                <svg width="13" height="13" viewBox="0 0 12 12" fill="#f5a623" aria-hidden="true">
                  <path d="M6 1l1.24 2.54 2.8.41-2.02 1.96.48 2.77L6 7.39 3.5 8.68l.48-2.77L2 3.95l2.76-.41L6 1z"/>
                </svg>
              {%- endfor -%}
            </div>
            <span>{{ section.settings.trust_text }}</span>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  {%- if section.settings.show_floating_badge and section.settings.promo_code != blank -%}
    <div class="hero-floating-badge" aria-hidden="true">
      <div class="hero-floating-badge__inner">
        <span class="hero-floating-badge__sale">SALE</span>
        <span class="hero-floating-badge__pct">
          {{ section.settings.floating_pct | default: '30' }}<small>%</small>
        </span>
        <span class="hero-floating-badge__off">OFF</span>
        <span class="hero-floating-badge__code">{{ section.settings.promo_code }}</span>
      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: 1920 × 1080px. Use a premium lifestyle bedroom photo."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Top badge text",
      "default": "Summer Sale"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Summer Sale"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Promo line (e.g. EXTRA 30% OFF)",
      "default": "EXTRA 30% OFF"
    },
    {
      "type": "text",
      "id": "promo_code",
      "label": "Promo code",
      "default": "EXTRA30"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Mini trust line (below buttons)",
      "default": "Rated 4.9 / 5 by over 12,400 happy customers"
    },
    {
      "type": "header",
      "content": "Floating Sale Badge"
    },
    {
      "type": "checkbox",
      "id": "show_floating_badge",
      "label": "Show circular sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "floating_pct",
      "label": "Badge percentage number",
      "default": "30"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button label",
          "default": "Shop Sale Now"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "button", "settings": { "label": "Shop Sale Now", "url": "/collections/all" } },
        { "type": "button", "settings": { "label": "Divan Beds", "url": "/collections/divan-beds" } },
        { "type": "button", "settings": { "label": "Ottoman Beds", "url": "/collections/ottoman-beds" } },
        { "type": "button", "settings": { "label": "Mattresses", "url": "/collections/mattresses" } }
      ]
    }
  ]
}
{% endschema %}
