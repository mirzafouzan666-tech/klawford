<section class="hero-banner">

  <!-- Full-bleed background: uses background-image div to bypass img{height:auto} -->
  <div class="hero-banner__bg" aria-hidden="true">
    {%- if section.settings.image != blank -%}
      <div class="hero-banner__bg-img" style="background-image: url('{{ section.settings.image | image_url: width: 1920 }}');"></div>
    {%- else -%}
      <div class="hero-banner__bg-img" style="background-image: url('{{ 'klawford_hero_banner_modern_bedroom.jpg' | asset_url }}');"></div>
    {%- endif -%}
  </div>

  <!-- Cream overlay — left panel solid, fades to transparent on right -->
  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <!-- Main content — left-aligned text -->
  <div class="hero-banner__inner">
    <div class="container">
      <div class="hero-banner__content">

        <!-- "Summer" — small word above big "Sale" -->
        {%- if section.settings.badge_text != blank -%}
          <span class="hero-word-small">{{ section.settings.badge_text }}</span>
        {%- endif -%}

        <!-- "Sale" — huge heading -->
        <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>

        {%- if section.settings.subheading != blank or section.settings.promo_code != blank -%}
          <p class="hero-banner__sub">
            {%- if section.settings.subheading != blank -%}{{ section.settings.subheading }}{%- endif -%}
            {%- if section.settings.promo_code != blank -%}
              <span class="hero-code-chip">{{ section.settings.promo_code }}</span>
            {%- endif -%}
          </p>
        {%- endif -%}

        {%- if section.settings.trust_text != blank -%}
          <div class="hero-mini-trust">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="6" fill="var(--clr-secondary)"/>
              <path d="M4.5 7l2 2 3-3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{{ section.settings.trust_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="hero-cta-btn">
            {{ section.settings.cta_label }}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}

      </div>
    </div>
  </div>

  <!-- Category buttons — left-aligned under text, like Sonno -->
  <div class="hero-banner__cats-bar">
    <div class="container">
      <div class="hero-cats-row">
        {%- assign cta_lower = section.settings.cta_label | downcase | strip -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' -%}
            {%- assign block_lower = block.settings.label | downcase | strip -%}
            {%- unless block_lower == cta_lower -%}
              <a href="{{ block.settings.url | default: '/collections/all' }}"
                 class="hero-cat-btn"
                 {{ block.shopify_attributes }}>
                {{ block.settings.label }}
              </a>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- if section.settings.show_floating_badge and section.settings.promo_code != blank -%}
    <div class="hero-floating-badge" aria-hidden="true">
      <div class="hero-floating-badge__inner">
        <span class="hero-floating-badge__sale">SALE</span>
        <span class="hero-floating-badge__pct">{{ section.settings.floating_pct | default: '30' }}<small>%</small></span>
        <span class="hero-floating-badge__off">OFF</span>
        <span class="hero-floating-badge__code">{{ section.settings.promo_code }}</span>
      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero background image",
      "info": "Recommended: wide landscape bedroom photo. Leave blank to use default."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Summer Sale"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Summer Sale"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Promo line (e.g. Extra 30% OFF with Code: EXTRA30)",
      "default": "Extra 30% OFF with Code: EXTRA30"
    },
    {
      "type": "text",
      "id": "promo_code",
      "label": "Promo code pill",
      "default": "EXTRA30"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust line",
      "default": "Auto Applies At Checkout"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop Sale Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Sale Badge"
    },
    {
      "type": "checkbox",
      "id": "show_floating_badge",
      "label": "Show circular sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "floating_pct",
      "label": "Badge percentage",
      "default": "30"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Category Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Beds"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "button", "settings": { "label": "Mattresses", "url": "/collections/mattresses" } },
        { "type": "button", "settings": { "label": "Divan Beds", "url": "/collections/divan-beds" } },
        { "type": "button", "settings": { "label": "Ottoman Beds", "url": "/collections/ottoman-beds" } },
        { "type": "button", "settings": { "label": "Headboards", "url": "/collections/headboards" } }
      ]
    }
  ]
}
{% endschema %}
