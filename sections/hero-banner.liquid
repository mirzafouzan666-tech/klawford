<section class="hero-banner">

  <div class="hero-banner__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 768 }} 768w,
                {{ section.settings.image | image_url: width: 1280 }} 1280w,
                {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape | default: shop.name }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="800">
    {%- else -%}
      <img
        src="{{ 'hero-placeholder.jpg' | asset_url }}"
        alt="{{ shop.name }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="800">
    {%- endif -%}
  </div>

  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <div class="hero-banner__inner">
    <div class="container">
      <div class="hero-banner__content">

        {%- if section.settings.badge_text != blank -%}
          <div class="hero-badge">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.badge_text }}
          </div>
        {%- endif -%}

        <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>

        {%- if section.settings.subheading != blank -%}
          <div class="hero-banner__sub">
            <span class="hero-check" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}

        <div class="hero-banner__buttons">
          {%- for block in section.blocks -%}
            {%- if block.type == 'button' -%}
              <a href="{{ block.settings.url }}" class="btn" {{ block.shopify_attributes }}>
                {{ block.settings.label }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended size: 1920 x 800px"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Top badge text",
      "default": "Spring Sale"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Spring Sale"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "EXTRA 25% OFF"
    },
    {
      "type": "text",
      "id": "promo_code",
      "label": "Promo code badge",
      "default": "EXTRA25"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "button", "settings": { "label": "Mattresses", "url": "/collections/mattresses" } },
        { "type": "button", "settings": { "label": "Divan Beds", "url": "/collections/divan-beds" } },
        { "type": "button", "settings": { "label": "Ottoman Beds", "url": "/collections/ottoman-beds" } }
      ]
    }
  ]
}
{% endschema %}
