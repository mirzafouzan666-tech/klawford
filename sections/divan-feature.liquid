<section class="feature-section">
  <div class="container">
    <div class="feature-section__grid {% if section.settings.image_position == 'left' %}feature-section__grid--reverse{% endif %}">

      <!-- Text content -->
      <div class="feature-section__content">
        {%- if section.settings.label != blank -%}
          <span class="feature-label">{{ section.settings.label }}</span>
        {%- endif -%}

        <h2 class="feature-heading">{{ section.settings.heading }}</h2>

        <ul class="feature-list" aria-label="Features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li class="feature-item" {{ block.shopify_attributes }}>
                <div class="feature-item__icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'happiness' -%}
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4"/>
                        <path d="M6.5 12s1 2 3.5 2 3.5-2 3.5-2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        <circle cx="7.5" cy="8" r="1" fill="currentColor"/>
                        <circle cx="12.5" cy="8" r="1" fill="currentColor"/>
                      </svg>
                    {%- when 'sustainable' -%}
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M10 3c-4.5 0-7 3-7 7s2.5 7 7 7 7-3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        <path d="M14 3l3 4h-3V3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                        <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {%- when 'customize' -%}
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M2 16l4-4 3 3-4 4-3-3zM13 2l5 5-8 8-5-5 8-8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                      </svg>
                    {%- when 'motion' -%}
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M3 10h14M10 3l7 7-7 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {%- else -%}
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M3 10l5 5 9-9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                  {%- endcase -%}
                </div>
                <div class="feature-item__body">
                  <p class="feature-item__title">{{ block.settings.title }}</p>
                  <p class="feature-item__desc">{{ block.settings.description }}</p>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url }}" class="btn btn--primary">
            {{ section.settings.cta_label }}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}

        <!-- Rating -->
        <div class="feature-rating">
          <div class="feature-rating__stars" aria-label="5 star rating">
            {%- for i in (1..5) -%}
              <div class="feature-rating__star" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
            {%- endfor -%}
          </div>
          <span class="feature-rating__text">{{ section.settings.rating_text | default: '4.9 / 5 · Trustpilot' }}</span>
        </div>

        <!-- Payment methods -->
        {%- if section.settings.show_payments -%}
          <div class="feature-payments" aria-label="Accepted payment methods">
            <span class="payment-pill">Visa</span>
            <span class="payment-pill">Mastercard</span>
            <span class="payment-pill">Amex</span>
            <span class="payment-pill">Apple Pay</span>
            <span class="payment-pill">Google Pay</span>
            <span class="payment-pill">Klarna</span>
            <span class="payment-pill">PayPal</span>
          </div>
        {%- endif -%}
      </div>

      <!-- Image -->
      <div class="feature-section__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                    {{ section.settings.image | image_url: width: 900 }} 900w"
            sizes="(max-width: 992px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | escape | default: section.settings.heading }}"
            loading="lazy"
            width="900"
            height="900">
        {%- else -%}
          <div class="feature-section__fallback-img" style="background-image: url('https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=900&q=85');"></div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Divan Beds Feature",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label (above heading)",
      "default": "Crafted with Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Klawford Divan Beds"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left",  "label": "Left"  }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Divan Beds"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "4.9 / 5 · 12,400 Trustpilot reviews"
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Show payment method badges",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "happiness",   "label": "Happiness" },
            { "value": "sustainable", "label": "Sustainable" },
            { "value": "customize",   "label": "Customisable" },
            { "value": "motion",      "label": "Motion / Arrow" },
            { "value": "check",       "label": "Check mark" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature title",
          "default": "Happiness Guaranteed"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature description",
          "default": "We're so committed to your satisfaction that after 6 months of use, if you're not happy with the product simply return it or swap for a new one."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divan Beds Feature",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "happiness",
            "title": "Happiness Guaranteed or Money Back",
            "description": "We're so committed to your satisfaction that after 6 months of use, if you're not happy with the product simply return it or swap for a new one."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "sustainable",
            "title": "Sustainably Sourced & Handmade in The UK",
            "description": "Within 30 days of your purchase we'll either refund or send you a new one."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "customize",
            "title": "Customisable Options for Your Specific Needs",
            "description": "Customisable options for color, size, storage, headboard and base types. Plus, the stylish design is guaranteed to look great for years."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "motion",
            "title": "Infinite Restless Movements",
            "description": "The responsive springs absorb motion and reduce partner disturbance, whether you suffer from allergies or not."
          }
        }
      ]
    }
  ]
}
{% endschema %}
